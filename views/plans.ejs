<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/theme.css">
  <style>
    .plans-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
    @media(max-width:800px){ .plans-grid { grid-template-columns:1fr; } }
    .plan-card { background:#0d0d0d; border:1px solid #1e1e1e; border-radius:14px; overflow:hidden; }
    .plan-card.active-plan { border-color:#2ecc71; }
    .plan-card-head { padding:18px 20px 12px; }
    .plan-card-title { font-size:1.05rem; font-weight:700; color:#e8e8e8; margin-bottom:4px; }
    .plan-card-sub   { font-size:0.8rem; color:#666; }
    .plan-card-body  { padding:0 20px 16px; }
    .phase-list { list-style:none; }
    .phase-item { padding:10px 0; border-top:1px solid #1a1a1a; }
    .phase-item:first-child { border-top:none; }
    .phase-name { font-weight:600; font-size:0.85rem; color:#e8e8e8; margin-bottom:6px; display:flex; align-items:center; gap:8px; }
    .phase-weeks { font-size:0.72rem; color:#555; background:#1a1a1a; padding:2px 8px; border-radius:10px; }
    .phase-days { display:flex; flex-direction:column; gap:4px; }
    .phase-day { font-size:0.78rem; color:#888; padding-left:12px; display:flex; gap:8px; }
    .phase-day .day-name { color:#666; min-width:30px; }
    .phase-day .day-desc { color:#aaa; }
    .plan-card-foot { padding:12px 20px; border-top:1px solid #1a1a1a; display:flex; gap:10px; flex-wrap:wrap; }
    .tag { display:inline-block; padding:2px 8px; border-radius:4px; font-size:0.68rem; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; }
    .tag-mma       { background:#2a1a1a; color:#e07b54; }
    .tag-bjj       { background:#1a1a2a; color:#9b59b6; }
    .tag-muay_thai { background:#2a1a1a; color:#e74c3c; }
    .tag-strength  { background:#1a2a4a; color:#5b9bd5; }
    .active-badge  { background:#1a2a1a; color:#2ecc71; border:1px solid #2ecc71; }
    .today-banner { background:#0e1a0e; border:1px solid #2a3a2a; border-radius:12px; padding:20px; margin-bottom:24px; }
    .today-banner-title { font-size:0.72rem; color:#2ecc71; font-weight:600; text-transform:uppercase; letter-spacing:1.5px; margin-bottom:8px; }
    .today-session-name { font-size:1.2rem; font-weight:700; color:#e8e8e8; margin-bottom:4px; }
    .today-session-desc { font-size:0.9rem; color:#aaa; margin-bottom:12px; }
    .assign-form { background:#0d0d0d; border:1px solid #1e1e1e; border-radius:12px; padding:20px; margin-bottom:24px; }
    .assign-form h3 { margin-bottom:14px; color:#e8e8e8; font-size:0.95rem; }
    .assign-row { display:flex; gap:10px; flex-wrap:wrap; align-items:flex-end; }
    .assign-row select, .assign-row input { background:#141414; border:1px solid #2a2a2a; border-radius:8px; padding:9px 12px; color:#e8e8e8; font-size:0.9rem; flex:1; min-width:140px; }
    .assign-row select:focus, .assign-row input:focus { outline:none; border-color:#2ecc71; }
    .toggle-phases { background:none; border:none; color:#555; font-size:0.8rem; cursor:pointer; padding:0; transition:color 0.15s; }
    .toggle-phases:hover { color:#2ecc71; }
    .phase-body { display:none; }
    .phase-body.open { display:block; }
    .day-names = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  </style>
</head>
<body>
  <%- include('partials/nav') %>

<div class="container" style="padding-top:24px">
  <h2 style="margin-bottom:20px">📋 Training Plans</h2>

  <% if (todaySession && todaySession.session) { %>
  <div class="today-banner">
    <div class="today-banner-title">
      📅 Today · <%= activePlan ? activePlan.name : '' %> · <%= todaySession.phase %> Phase · Week <%= todaySession.weekNumber %>
    </div>
    <div class="today-session-name"><%= todaySession.session.title %></div>
    <% if (todaySession.session.description) { %>
    <div class="today-session-desc"><%= todaySession.session.description %></div>
    <% } %>
    <a href="/workout" class="btn btn-green">▶ Start This Session</a>
  </div>
  <% } else if (assignment) { %>
  <div class="today-banner">
    <div class="today-banner-title">📅 Active Plan · <%= activePlan ? activePlan.name : '' %></div>
    <div class="today-session-name" style="color:#888">Rest day — no session scheduled for today.</div>
    <div style="margin-top:10px">
      <a href="/workout" class="btn">Open Workout Logger</a>
    </div>
  </div>
  <% } %>

  <!-- Assign / change plan -->
  <div class="assign-form">
    <h3>⚡ Assign a Plan</h3>
    <form action="/plans/assign" method="POST">
      <div class="assign-row">
        <select name="planId" required>
          <option value="">Select plan…</option>
          <% plans.forEach(p => { %>
          <option value="<%= p.id %>" <%= (assignment && assignment.planId === p.id) ? 'selected' : '' %>>
            <%= p.name %>
          </option>
          <% }) %>
        </select>
        <input type="date" name="startDate" value="<%= new Date().toISOString().split('T')[0] %>">
        <button type="submit" class="btn btn-green">Assign</button>
      </div>
    </form>
    <% if (assignment) { %>
    <form action="/plans/unassign" method="POST" style="margin-top:10px">
      <button type="submit" class="btn" style="font-size:0.8rem;padding:6px 14px;color:#e74c3c;border-color:#3a1a1a">
        ✕ Unassign Current Plan
      </button>
    </form>
    <% } %>
  </div>

  <!-- Plan cards -->
  <div class="plans-grid">
    <% plans.forEach(plan => { %>
    <%
      const isActive = assignment && assignment.planId === plan.id;
      const sportTag = 'tag-' + (plan.sport || 'mma');
    %>
    <div class="plan-card <%= isActive ? 'active-plan' : '' %>">
      <div class="plan-card-head">
        <div class="plan-card-title">
          <%= plan.name %>
          <% if (isActive) { %><span class="tag active-badge" style="margin-left:8px;font-size:0.65rem">✓ Active</span><% } %>
        </div>
        <div class="plan-card-sub">
          <%= plan.durationWeeks %> weeks
          <% if (plan.description) { %> · <%= plan.description %><% } %>
        </div>
      </div>
      <div class="plan-card-body">
        <ul class="phase-list">
          <% plan.phases.forEach((phase, pi) => { %>
          <li class="phase-item">
            <div class="phase-name">
              <%= phase.name %> Phase
              <span class="phase-weeks">Weeks <%= phase.weeks %></span>
              <button class="toggle-phases" onclick="togglePhase('<%= plan.id %>-<%= pi %>')">▼ schedule</button>
            </div>
            <% if (phase.focus) { %>
            <div style="font-size:0.75rem;color:#666;margin-bottom:6px;padding-left:2px"><%= phase.focus %></div>
            <% } %>
            <div class="phase-body" id="phase-<%= plan.id %>-<%= pi %>">
              <div class="phase-days">
                <% if (phase.weeklySchedule) { phase.weeklySchedule.forEach(day => { %>
                <div class="phase-day">
                  <span class="day-name"><%= ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][day.day] %></span>
                  <span class="day-desc"><%= day.title %><% if(day.description){%> — <%= day.description %><% } %></span>
                </div>
                <% }); } %>
              </div>
            </div>
          </li>
          <% }) %>
        </ul>
      </div>
      <div class="plan-card-foot">
        <span class="tag <%= sportTag %>"><%= (plan.sport||'mma').replace('_',' ') %></span>
        <% if (!isActive) { %>
        <form action="/plans/assign" method="POST" style="margin-left:auto">
          <input type="hidden" name="planId" value="<%= plan.id %>">
          <input type="hidden" name="startDate" value="<%= new Date().toISOString().split('T')[0] %>">
          <button type="submit" class="btn" style="padding:4px 12px;font-size:0.8rem">Use This Plan</button>
        </form>
        <% } %>
      </div>
    </div>
    <% }) %>
  </div>

  <% if (plans.length === 0) { %>
  <div style="text-align:center;padding:60px 20px;color:#555">
    No training plans yet. Plans are seeded on first login.
  </div>
  <% } %>

</div>

<script>
function togglePhase(id) {
  const el = document.getElementById('phase-' + id);
  if (!el) return;
  el.classList.toggle('open');
  const btn = el.previousElementSibling;
  if (btn && btn.classList.contains('toggle-phases')) {
    btn.textContent = el.classList.contains('open') ? '▲ hide' : '▼ schedule';
  }
}
</script>
</body>
</html>
