<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/theme.css">
</head>
<body>
    <%- include('partials/nav') %>

    <div class="container">
        <div class="card">
            <h2>🎯 Create Goal</h2>
            <form method="POST" action="/goals">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Goal Type</label>
                        <select name="type" required>
                            <option value="weight">Weight Goal</option>
                            <option value="exercise">Exercise Goal</option>
                            <option value="calories">Calorie Goal</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Target Value</label>
                        <input type="number" step="0.1" name="targetValue" required>
                    </div>
                    <div class="form-group">
                        <label>Current Value (optional)</label>
                        <input type="number" step="0.1" name="currentValue">
                    </div>
                    <div class="form-group">
                        <label>Deadline (optional)</label>
                        <input type="date" name="deadline">
                    </div>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="description" rows="2" placeholder="Describe your goal..."></textarea>
                </div>
                <button type="submit">Create Goal</button>
            </form>
        </div>

        <div class="card">
            <h2>Your Goals</h2>
            <% if (goals.length > 0) { %>
                <% goals.forEach(goal => { %>
                    <div class="goal-item <%= goal.completed ? 'completed' : '' %>">
                        <div class="goal-header">
                            <div>
                                <strong><%= goal.type.charAt(0).toUpperCase() + goal.type.slice(1) %> Goal</strong>
                                <% if (goal.completed) { %>
                                    <span style="color: #5df59a; margin-left: 10px;">✓ Completed</span>
                                <% } %>
                            </div>
                            <div class="goal-actions">
                                <form method="POST" action="/goals/toggle/<%= goal.id %>" style="display: inline;">
                                    <button type="submit" class="toggle-btn">
                                        <%= goal.completed ? 'Reopen' : 'Complete' %>
                                    </button>
                                </form>
                                <form method="POST" action="/goals/delete/<%= goal.id %>" style="display: inline;">
                                    <button type="submit" class="delete-btn">Delete</button>
                                </form>
                            </div>
                        </div>
                        <div>
                            <strong>Target:</strong> <%= goal.targetValue %>
                            <% if (goal.currentValue) { %>
                                | <strong>Current:</strong> <%= goal.currentValue %>
                            <% } %>
                            <% if (goal.deadline) { %>
                                | <strong>Deadline:</strong> <%= new Date(goal.deadline).toLocaleDateString() %>
                            <% } %>
                        </div>
                        <% if (goal.description) { %>
                            <div style="margin-top: 8px; color: #888;">
                                <%= goal.description %>
                            </div>
                        <% } %>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="empty-state">No goals set yet. Create your first goal above!</p>
            <% } %>
        </div>
    </div>
</body>
</html>
