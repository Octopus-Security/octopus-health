<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/theme.css">
</head>
<body>
    <%- include('partials/nav') %>

    <div class="container">
        <h1 style="margin: 30px 0;">Welcome, <%= user.username %>!</h1>

        <!-- ── Competition Widget ── -->
        <% if (competitionWidget) { %>
        <div class="comp-widget">
            <div class="comp-widget-left">
                <span class="sport-badge sport-<%= competitionWidget.sport %>" style="margin-bottom: 4px; display:inline-block;">
                    <%= competitionWidget.sport === 'muay_thai' ? '🥊 Muay Thai' : competitionWidget.sport === 'bjj' ? '🥋 BJJ' : '🏆' %>
                </span>
                <div class="comp-widget-name"><%= competitionWidget.name %></div>
                <div class="comp-widget-sub">
                    <%= competitionWidget.phase.weeksOut %> weeks out
                    <% if (competitionWidget.weightClass) { %>· <%= competitionWidget.weightClass %><% } %>
                </div>
                <% if (competitionWidget.regWarning) { %>
                <div class="reg-warning" style="margin-top: 6px;">⚠️ Register within <%= competitionWidget.regWarning %> days</div>
                <% } %>
            </div>
            <div class="comp-widget-phase">
                <span class="phase-badge" style="background: <%= competitionWidget.phase.color %>22; color: <%= competitionWidget.phase.color %>; border: 1px solid <%= competitionWidget.phase.color %>44; font-size: 14px; padding: 6px 14px;">
                    <%= competitionWidget.phase.phase %>
                </span>
                <a href="/competitions" class="btn" style="margin-top: 10px; display: block; text-align: center; padding: 6px 14px; font-size: 12px;">View all</a>
            </div>
        </div>
        <% } %>

        <!-- ── Today's Sessions ── -->
        <% if (todaySessions && todaySessions.length > 0) { %>
        <div class="card" style="margin-bottom: 20px;">
            <h2>🗓 Today's Sessions</h2>
            <% todaySessions.forEach(s => { %>
                <div class="list-item" style="display:flex; justify-content:space-between; align-items:center;">
                    <span>
                        <strong><%= s.type.replace('_',' ') %></strong>
                        <% if (s.title) { %> — <%= s.title %><% } %>
                        <% if (s.plannedDuration) { %> · <%= s.plannedDuration %>min<% } %>
                    </span>
                    <span class="status-badge status-<%= s.status %>"><%= s.status %></span>
                </div>
            <% }) %>
            <a href="/planner" class="btn" style="margin-top: 12px;">Go to Planner</a>
        </div>
        <% } %>

        <div class="dashboard-grid">
            <div class="card">
                <h2>⚖️ Current Weight</h2>
                <% if (recentWeight) { %>
                    <div class="stat"><%= recentWeight.weight %> <%= recentWeight.unit %></div>
                    <div class="stat-label">Last updated: <%= new Date(recentWeight.date).toLocaleDateString() %></div>
                <% } else { %>
                    <div class="empty-state">No weight entries yet</div>
                <% } %>
            </div>

            <div class="card">
                <h2>🏃 Today's Exercise</h2>
                <div class="stat"><%= todayExerciseMinutes %> min</div>
                <div class="stat-label"><%= todayExercises.length %> activities</div>
            </div>

            <div class="card">
                <h2>🍽️ Today's Calories</h2>
                <div class="stat"><%= todayCalories %></div>
                <div class="stat-label"><%= todayMeals.length %> meals logged</div>
            </div>

            <div class="card">
                <h2>🎯 Active Goals</h2>
                <div class="stat"><%= activeGoals.length %></div>
                <div class="stat-label">goals in progress</div>
            </div>
        </div>

        <div class="dashboard-grid">
            <div class="card">
                <h2>Today's Exercises</h2>
                <% if (todayWorkoutSessions && todayWorkoutSessions.length > 0) { %>
                    <% todayWorkoutSessions.forEach(session => { %>
                        <div style="margin-bottom:14px; border:1px solid #1e1e1e; border-radius:8px; overflow:hidden;">
                            <div style="background:#141414; padding:8px 12px; display:flex; justify-content:space-between; align-items:center;">
                                <strong style="color:#e8e8e8"><%= session.title || session.type %></strong>
                                <% if (session.duration) { %><span style="font-size:0.75rem;color:#555"><%= session.duration %> min</span><% } %>
                            </div>
                            <% if (session.exercises && session.exercises.length > 0) { %>
                                <table style="width:100%; font-size:0.8rem; border-collapse:collapse;">
                                    <% session.exercises.forEach(ex => { %>
                                        <tr style="border-top:1px solid #1a1a1a;">
                                            <td style="padding:6px 12px; color:#aaa; font-weight:500; white-space:nowrap"><%= ex.name %></td>
                                            <td style="padding:6px 12px; color:#666; text-align:right">
                                                <%= ex.sets.map(s => {
                                                    if (s.duration) return s.duration + 's';
                                                    const r = s.reps ? s.reps + ' reps' : '';
                                                    const w = s.weight ? s.weight + (s.weightUnit || 'lbs') : '';
                                                    return [r, w].filter(Boolean).join(' @ ') || '✓';
                                                }).join(' · ') %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </table>
                            <% } %>
                        </div>
                    <% }) %>
                <% } else if (todayExercises.length > 0) { %>
                    <% todayExercises.forEach(exercise => { %>
                        <div class="list-item">
                            <strong><%= exercise.type %></strong><br>
                            <%= exercise.duration %> minutes
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="empty-state">No exercises logged today</div>
                <% } %>
                <a href="/workout" class="btn" style="margin-top: 15px;">Log Exercise</a>
            </div>

            <div class="card">
                <h2>Today's Meals</h2>
                <% if (todayMeals.length > 0) { %>
                    <% todayMeals.slice(0, 3).forEach(meal => { %>
                        <div class="list-item">
                            <strong><%= meal.mealType %></strong><br>
                            <%= meal.description.substring(0, 50) %>...
                            <% if (meal.calories) { %>
                                <br><small><%= meal.calories %> cal</small>
                            <% } %>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="empty-state">No meals logged today</div>
                <% } %>
                <a href="/meals" class="btn" style="margin-top: 15px;">Log Meal</a>
            </div>
        </div>
    </div>
</body>
</html>
