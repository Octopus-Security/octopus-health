<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/theme.css">
</head>
<body>
    <%- include('partials/nav') %>

    <div class="container">
        <div class="card">
            <h2>🏃 Log Exercise</h2>
            <form method="POST" action="/exercise">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Date</label>
                        <input type="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>" required>
                    </div>
                    <div class="form-group">
                        <label>Type (Running, Gym, Cycling, etc.)</label>
                        <input type="text" name="type" required>
                    </div>
                    <div class="form-group">
                        <label>Duration (minutes)</label>
                        <input type="number" name="duration" required>
                    </div>
                    <div class="form-group">
                        <label>Calories (optional)</label>
                        <input type="number" name="calories">
                    </div>
                    <div class="form-group">
                        <label>Distance (optional)</label>
                        <input type="number" step="0.1" name="distance">
                    </div>
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea name="notes" rows="2"></textarea>
                </div>
                <button type="submit">Log Exercise</button>
            </form>
        </div>

        <div class="card">
            <h2>Exercise History</h2>
            <% if (exercises.length > 0) { %>
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Duration</th>
                            <th>Calories</th>
                            <th>Distance</th>
                            <th>Notes</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% exercises.forEach(ex => { %>
                            <tr>
                                <td><%= new Date(ex.date).toLocaleDateString() %></td>
                                <td><%= ex.type %></td>
                                <td><%= ex.duration %> min</td>
                                <td><%= ex.calories || '-' %></td>
                                <td><%= ex.distance || '-' %></td>
                                <td><%= ex.notes || '-' %></td>
                                <td>
                                    <form method="POST" action="/exercise/delete/<%= ex.id %>" style="display: inline;">
                                        <button type="submit" class="delete-btn">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <p class="empty-state">No exercises logged yet. Add your first one above!</p>
            <% } %>
        </div>
    </div>
</body>
</html>
