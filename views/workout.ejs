<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/theme.css">
  <style>
    .workout-grid { display: grid; grid-template-columns: 1fr 340px; gap: 20px; }
    @media(max-width:900px){ .workout-grid { grid-template-columns: 1fr; } }
    .session-header { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; margin-bottom:16px; }
    .session-timer  { font-size:2rem; font-weight:700; font-variant-numeric:tabular-nums; color:#2ecc71; letter-spacing:2px; }
    .exercise-block { background:#0d0d0d; border:1px solid #2a2a2a; border-radius:10px; margin-bottom:12px; overflow:hidden; }
    .exercise-block-header { padding:10px 14px; display:flex; align-items:center; justify-content:space-between; background:#141414; }
    .exercise-block-name   { font-weight:600; color:#e8e8e8; font-size:0.95rem; }
    .exercise-block-meta   { font-size:0.75rem; color:#666; margin-top:2px; }
    .set-row { display:grid; grid-template-columns:32px 1fr 1fr 40px; gap:6px; align-items:center; padding:6px 14px; border-top:1px solid #1a1a1a; }
    .set-num { color:#555; font-size:0.8rem; text-align:center; }
    .set-input { background:#1a1a1a; border:1px solid #2a2a2a; border-radius:6px; padding:5px 8px; color:#e8e8e8; font-size:0.9rem; width:100%; }
    .set-input:focus { outline:none; border-color:#2ecc71; }
    .btn-add-set { width:100%; padding:7px; background:#1a2a1a; border:1px dashed #2a4a2a; color:#2ecc71; border-radius:0 0 10px 10px; cursor:pointer; font-size:0.85rem; transition:background 0.15s; }
    .btn-add-set:hover { background:#1e361e; }
    .btn-del-set { background:none; border:none; color:#444; cursor:pointer; font-size:0.9rem; padding:2px; }
    .btn-del-set:hover { color:#e74c3c; }
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.8); z-index:100; align-items:center; justify-content:center; }
    .modal-overlay.open { display:flex; }
    .modal { background:#111; border:1px solid #222; border-radius:14px; padding:24px; width:min(520px,95vw); max-height:85vh; overflow-y:auto; }
    .modal h3 { color:#e8e8e8; margin-bottom:16px; }
    .search-input { width:100%; background:#0d0d0d; border:1px solid #2a2a2a; border-radius:8px; padding:10px 14px; color:#e8e8e8; font-size:0.95rem; margin-bottom:12px; }
    .search-input:focus { outline:none; border-color:#2ecc71; }
    .ex-list { list-style:none; }
    .ex-list li { padding:10px 12px; border-radius:8px; cursor:pointer; border:1px solid transparent; margin-bottom:4px; transition:background 0.1s; }
    .ex-list li:hover { background:#1a1a1a; border-color:#2a2a2a; }
    .ex-list .ex-name { font-weight:500; color:#e8e8e8; font-size:0.9rem; }
    .ex-list .ex-tags { font-size:0.72rem; color:#555; margin-top:2px; }
    .cat-tabs { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:12px; }
    .cat-tab { padding:4px 12px; border-radius:20px; border:1px solid #2a2a2a; background:#0d0d0d; color:#888; font-size:0.78rem; cursor:pointer; transition:all 0.15s; }
    .cat-tab.active { background:#1a2a1a; border-color:#2ecc71; color:#2ecc71; }
    .finish-form { display:grid; gap:12px; }
    .effort-row { display:flex; gap:8px; }
    .effort-btn { flex:1; padding:8px; border:1px solid #2a2a2a; background:#0d0d0d; color:#888; border-radius:8px; cursor:pointer; font-size:0.85rem; transition:all 0.15s; text-align:center; }
    .effort-btn.selected, .effort-btn:hover { background:#1a2a1a; border-color:#2ecc71; color:#2ecc71; }
    .rest-banner { position:fixed; bottom:20px; right:20px; background:#111; border:1px solid #2ecc71; border-radius:12px; padding:14px 20px; z-index:50; display:none; align-items:center; gap:14px; }
    .rest-banner.show { display:flex; }
    .rest-time { font-size:1.4rem; font-weight:700; color:#2ecc71; font-variant-numeric:tabular-nums; }
    .tag { display:inline-block; padding:2px 8px; border-radius:4px; font-size:0.7rem; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; }
    .tag-strength    { background:#1a2a4a; color:#5b9bd5; }
    .tag-mma         { background:#2a1a1a; color:#e07b54; }
    .tag-bjj         { background:#1a1a2a; color:#9b59b6; }
    .tag-muay_thai   { background:#2a1a1a; color:#e74c3c; }
    .tag-conditioning{ background:#1a2a1a; color:#2ecc71; }
    .tag-cardio      { background:#1a2520; color:#1abc9c; }
    .tag-recovery    { background:#252020; color:#95a5a6; }
    .history-item { display:flex; align-items:center; justify-content:space-between; padding:10px 14px; border-radius:8px; border:1px solid #1e1e1e; margin-bottom:6px; cursor:pointer; transition:background 0.1s; }
    .history-item:hover { background:#141414; }
    /* Template card styles */
    .template-card { background:#0d0d0d; border:1px solid #2a2a2a; border-radius:10px; margin-bottom:10px; overflow:hidden; transition:border-color 0.15s; }
    .template-card:hover { border-color:#3a3a3a; }
    .template-card-header { padding:10px 14px; background:#141414; display:flex; align-items:center; justify-content:space-between; gap:8px; }
    .template-card-name { font-weight:600; color:#e8e8e8; font-size:0.9rem; }
    .template-card-body { padding:8px 14px 10px; }
    .template-ex-chip { display:inline-block; background:#1a1a1a; border:1px solid #252525; border-radius:12px; padding:2px 8px; font-size:0.72rem; color:#888; margin:2px 3px 2px 0; }
    .template-actions { display:flex; gap:6px; }
    /* Builder exercise card */
    .builder-ex-card { display:flex; align-items:center; justify-content:space-between; padding:8px 12px; background:#0d0d0d; border:1px solid #2a2a2a; border-radius:8px; margin-bottom:6px; }
    .builder-ex-name { font-size:0.88rem; font-weight:500; color:#e8e8e8; }
    .builder-ex-meta { font-size:0.72rem; color:#666; margin-top:1px; }
  </style>
</head>
<body>
<%- include('partials/nav') %>

<div class="container" style="padding-top:24px">

  <% if (todayPlan && todayPlan.session) { %>
  <div class="card" style="margin-bottom:16px; border-color:#2a3a2a; background:#0e1a0e;">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px">
      <div>
        <div style="font-size:0.75rem;color:#2ecc71;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:4px">
          📋 Today's Plan · <%= todayPlan.planName %> · <%= todayPlan.phase %> Phase
        </div>
        <div style="font-size:1.05rem;font-weight:600;color:#e8e8e8"><%= todayPlan.session.title %></div>
        <div style="font-size:0.85rem;color:#aaa;margin-top:3px"><%= todayPlan.session.description %></div>
      </div>
      <button onclick="startWorkout('<%= todayPlan.session.type %>','<%= todayPlan.session.title %>')" class="btn" style="white-space:nowrap">
        ▶ Start This Session
      </button>
    </div>
  </div>
  <% } %>

  <div class="workout-grid">

    <!-- ── Active / Start Workout ── -->
    <div>
      <div id="start-panel">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
          <h2 style="margin:0">🏋️ Workout Logger</h2>
          <button onclick="openStartModal()" class="btn">+ New Workout</button>
        </div>
        <div id="no-session" style="text-align:center;padding:60px 20px;color:#555;font-size:0.9rem">
          No active workout. Hit <strong style="color:#2ecc71">New Workout</strong> to start logging,
          or load one of your saved workouts on the right.
        </div>
      </div>

      <!-- Active session UI (hidden until session created) -->
      <div id="active-session" style="display:none">
        <div class="card" style="border-color:#2a3a2a">
          <div class="session-header">
            <div>
              <div id="session-type-label" class="tag" style="margin-bottom:6px"></div>
              <div id="session-title-label" style="font-size:1.1rem;font-weight:600;color:#e8e8e8"></div>
            </div>
            <div class="session-timer" id="session-timer">00:00</div>
            <div style="display:flex;gap:8px">
              <a href="/timers" target="_blank" class="btn" style="font-size:0.8rem;padding:6px 12px">⏱ Timers</a>
              <button onclick="openFinishModal()" class="btn btn-green" style="font-size:0.85rem">Finish ✓</button>
            </div>
          </div>
        </div>

        <div id="exercises-container"></div>

        <button onclick="openExerciseModal()" class="btn" style="width:100%;margin-top:4px;padding:12px;border-style:dashed">
          + Add Exercise
        </button>
      </div>
    </div>

    <!-- ── Right Sidebar: My Workouts + Recent History ── -->
    <div>

      <!-- My Workouts (Templates) -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
        <h3 style="margin:0;color:#e8e8e8">📋 My Workouts</h3>
        <button onclick="openTemplateBuilder()" class="btn" style="font-size:0.78rem;padding:5px 12px">+ New</button>
      </div>
      <div id="templates-container">
        <% if (!templates || !templates.length) { %>
          <p style="color:#555;font-size:0.85rem;margin-bottom:20px">No saved workouts yet. Hit <strong style="color:#aaa">+ New</strong> to build one.</p>
        <% } else { %>
          <% templates.forEach(t => { %>
          <div class="template-card" id="tpl-<%= t.id %>">
            <div class="template-card-header">
              <div>
                <span class="tag tag-<%= t.type %>" style="margin-bottom:4px;display:inline-block"><%= t.type %></span>
                <div class="template-card-name"><%= t.name %></div>
                <div style="font-size:0.72rem;color:#555;margin-top:1px"><%= t.exercises.length %> exercise<%= t.exercises.length !== 1 ? 's' : '' %></div>
              </div>
              <div class="template-actions">
                <button onclick="loadTemplate(<%= t.id %>)" class="btn btn-green" style="font-size:0.75rem;padding:5px 10px">▶ Load</button>
                <button onclick="deleteTemplate(<%= t.id %>)" style="background:none;border:none;color:#444;cursor:pointer;font-size:0.85rem;padding:4px 6px" title="Delete">🗑</button>
              </div>
            </div>
            <% if (t.exercises.length) { %>
            <div class="template-card-body">
              <% t.exercises.slice(0,6).forEach(e => { %>
                <span class="template-ex-chip"><%= e.exerciseName %></span>
              <% }) %>
              <% if (t.exercises.length > 6) { %><span class="template-ex-chip">+<%= t.exercises.length - 6 %> more</span><% } %>
            </div>
            <% } %>
          </div>
          <% }) %>
        <% } %>
      </div>

      <hr style="border-color:#1e1e1e;margin:16px 0">

      <!-- Recent Sessions -->
      <h3 style="margin-bottom:12px;color:#e8e8e8">Recent Sessions</h3>
      <% if (!recentWorkouts.length) { %>
        <p style="color:#555;font-size:0.9rem">No workouts yet.</p>
      <% } else { %>
        <% recentWorkouts.forEach(w => { %>
        <div class="history-item" onclick="viewSession(<%= w.id %>)">
          <div>
            <div style="font-size:0.8rem;color:#555;margin-bottom:2px"><%= w.date %></div>
            <div style="font-weight:500;color:#e8e8e8;font-size:0.9rem"><%= w.title || w.type %></div>
            <div style="font-size:0.75rem;color:#666;margin-top:1px">
              <%= w.exerciseCount %> exercises · <%= w.setCount %> sets<% if(w.duration){ %> · <%= w.duration %> min<% } %>
            </div>
          </div>
          <div style="text-align:right">
            <span class="tag tag-<%= w.type %>"><%= w.type %></span>
            <% if(w.effort){ %><div style="font-size:0.75rem;color:#888;margin-top:4px">RPE <%= '★'.repeat(w.effort) %></div><% } %>
          </div>
        </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

<!-- ── Start Modal ── -->
<div class="modal-overlay" id="start-modal">
  <div class="modal">
    <h3>Start Workout</h3>
    <div style="margin-bottom:14px">
      <label style="font-size:0.85rem;color:#888;display:block;margin-bottom:6px">Type</label>
      <div class="cat-tabs" id="type-tabs">
        <div class="cat-tab active" data-type="strength">💪 Strength</div>
        <div class="cat-tab" data-type="mma">🥊 MMA</div>
        <div class="cat-tab" data-type="bjj">🥋 BJJ</div>
        <div class="cat-tab" data-type="muay_thai">🦵 Muay Thai</div>
        <div class="cat-tab" data-type="conditioning">🏃 Conditioning</div>
        <div class="cat-tab" data-type="cardio">🚴 Cardio</div>
        <div class="cat-tab" data-type="recovery">🧘 Recovery</div>
      </div>
    </div>
    <div style="margin-bottom:16px">
      <label style="font-size:0.85rem;color:#888;display:block;margin-bottom:6px">Title (optional)</label>
      <input type="text" id="start-title" class="search-input" style="margin:0" placeholder="e.g. Push Day, Sparring, etc.">
    </div>
    <div style="display:flex;gap:10px">
      <button onclick="closeStartModal()" class="btn" style="flex:1;background:#1a1a1a">Cancel</button>
      <button onclick="confirmStart()" class="btn btn-green" style="flex:1">Start ▶</button>
    </div>
  </div>
</div>

<!-- ── Exercise Picker Modal (for active session) ── -->
<div class="modal-overlay" id="exercise-modal">
  <div class="modal">
    <h3>Add Exercise</h3>
    <input type="text" id="ex-search" class="search-input" placeholder="Search exercises…" oninput="filterExercises()">
    <div class="cat-tabs" id="ex-cat-tabs">
      <div class="cat-tab active" data-cat="">All</div>
      <div class="cat-tab" data-cat="barbell">Barbell</div>
      <div class="cat-tab" data-cat="dumbbell">Dumbbell</div>
      <div class="cat-tab" data-cat="cable">Cable</div>
      <div class="cat-tab" data-cat="machine">Machine</div>
      <div class="cat-tab" data-cat="bodyweight">Bodyweight</div>
      <div class="cat-tab" data-cat="mma">MMA</div>
      <div class="cat-tab" data-cat="bjj">BJJ</div>
      <div class="cat-tab" data-cat="muay_thai">Muay Thai</div>
      <div class="cat-tab" data-cat="conditioning">Conditioning</div>
      <div class="cat-tab" data-cat="cardio">Cardio</div>
      <div class="cat-tab" data-cat="recovery">Recovery</div>
    </div>
    <ul class="ex-list" id="ex-list" style="max-height:300px;overflow-y:auto"></ul>
    <div style="display:flex;gap:8px;margin-top:12px">
      <input type="text" id="custom-ex-name" class="search-input" style="margin-bottom:0;flex:1" placeholder="Or type custom exercise name…">
      <button onclick="addCustomExercise()" class="btn btn-green">Add</button>
    </div>
    <button onclick="closeExerciseModal()" class="btn" style="width:100%;margin-top:10px;background:#1a1a1a">Cancel</button>
  </div>
</div>

<!-- ── Finish Modal ── -->
<div class="modal-overlay" id="finish-modal">
  <div class="modal">
    <h3>Finish Workout</h3>
    <div class="finish-form">
      <div>
        <label style="font-size:0.85rem;color:#888;display:block;margin-bottom:8px">Effort (1–5)</label>
        <div class="effort-row" id="effort-row">
          <div class="effort-btn" data-val="1">1<br><span style="font-size:0.7rem">Easy</span></div>
          <div class="effort-btn" data-val="2">2<br><span style="font-size:0.7rem">Light</span></div>
          <div class="effort-btn selected" data-val="3">3<br><span style="font-size:0.7rem">Moderate</span></div>
          <div class="effort-btn" data-val="4">4<br><span style="font-size:0.7rem">Hard</span></div>
          <div class="effort-btn" data-val="5">5<br><span style="font-size:0.7rem">Max</span></div>
        </div>
      </div>
      <div>
        <label style="font-size:0.85rem;color:#888;display:block;margin-bottom:6px">Notes</label>
        <textarea id="finish-notes" rows="3" style="width:100%;background:#0d0d0d;border:1px solid #2a2a2a;border-radius:8px;padding:8px 12px;color:#e8e8e8;resize:vertical" placeholder="How did it feel? PRs? What to work on?"></textarea>
      </div>
      <div>
        <label style="font-size:0.85rem;color:#888;display:block;margin-bottom:6px">
          <input type="checkbox" id="save-as-template-check" style="margin-right:6px">
          Save as workout template
        </label>
        <input type="text" id="template-name-input" class="search-input" style="margin:6px 0 0;display:none" placeholder="Template name…">
      </div>
      <div style="display:flex;gap:10px">
        <button onclick="closeFinishModal()" class="btn" style="flex:1;background:#1a1a1a">Back</button>
        <button onclick="confirmFinish()" class="btn btn-green" style="flex:1">Save Workout ✓</button>
      </div>
      <button onclick="discardSession()" style="width:100%;padding:8px;background:none;border:none;color:#555;cursor:pointer;font-size:0.8rem">Discard workout</button>
    </div>
  </div>
</div>

<!-- ── Template Builder Modal ── -->
<div class="modal-overlay" id="builder-modal">
  <div class="modal" style="width:min(560px,95vw)">
    <h3>Build Workout Template</h3>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">
      <div>
        <label style="font-size:0.8rem;color:#888;display:block;margin-bottom:5px">Name</label>
        <input type="text" id="builder-name" class="search-input" style="margin:0" placeholder="e.g. Push Day A">
      </div>
      <div>
        <label style="font-size:0.8rem;color:#888;display:block;margin-bottom:5px">Type</label>
        <select id="builder-type" style="width:100%;background:#0d0d0d;border:1px solid #2a2a2a;border-radius:8px;padding:10px 12px;color:#e8e8e8;font-size:0.9rem">
          <option value="strength">💪 Strength</option>
          <option value="mma">🥊 MMA</option>
          <option value="bjj">🥋 BJJ</option>
          <option value="muay_thai">🦵 Muay Thai</option>
          <option value="conditioning">🏃 Conditioning</option>
          <option value="cardio">🚴 Cardio</option>
          <option value="recovery">🧘 Recovery</option>
        </select>
      </div>
    </div>

    <div id="builder-exercises" style="min-height:40px;margin-bottom:12px"></div>

    <button onclick="openBuilderExPicker()" class="btn" style="width:100%;border-style:dashed;margin-bottom:14px;padding:10px">
      + Add Exercise to Template
    </button>

    <div style="display:flex;gap:10px">
      <button onclick="closeTemplateBuilder()" class="btn" style="flex:1;background:#1a1a1a">Cancel</button>
      <button onclick="saveTemplate()" class="btn btn-green" style="flex:1">Save Template ✓</button>
    </div>
  </div>
</div>

<!-- ── Builder Exercise Picker Modal ── -->
<div class="modal-overlay" id="builder-ex-modal">
  <div class="modal">
    <h3>Add to Template</h3>
    <input type="text" id="bex-search" class="search-input" placeholder="Search exercises…" oninput="filterBuilderExercises()">
    <div class="cat-tabs" id="bex-cat-tabs">
      <div class="cat-tab active" data-cat="">All</div>
      <div class="cat-tab" data-cat="barbell">Barbell</div>
      <div class="cat-tab" data-cat="dumbbell">Dumbbell</div>
      <div class="cat-tab" data-cat="cable">Cable</div>
      <div class="cat-tab" data-cat="machine">Machine</div>
      <div class="cat-tab" data-cat="bodyweight">Bodyweight</div>
      <div class="cat-tab" data-cat="mma">MMA</div>
      <div class="cat-tab" data-cat="bjj">BJJ</div>
      <div class="cat-tab" data-cat="muay_thai">Muay Thai</div>
      <div class="cat-tab" data-cat="conditioning">Conditioning</div>
      <div class="cat-tab" data-cat="cardio">Cardio</div>
      <div class="cat-tab" data-cat="recovery">Recovery</div>
    </div>
    <ul class="ex-list" id="bex-list" style="max-height:300px;overflow-y:auto"></ul>
    <div style="display:flex;gap:8px;margin-top:12px">
      <input type="text" id="bex-custom" class="search-input" style="margin-bottom:0;flex:1" placeholder="Or type custom exercise name…">
      <button onclick="addCustomToBuilder()" class="btn btn-green">Add</button>
    </div>
    <button onclick="closeBuilderExPicker()" class="btn" style="width:100%;margin-top:10px;background:#1a1a1a">Cancel</button>
  </div>
</div>

<!-- ── Session Detail Modal ── -->
<div class="modal-overlay" id="session-detail-modal">
  <div class="modal" style="width:min(480px,95vw)">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:4px">
      <div>
        <h3 style="margin:0" id="sd-title"></h3>
        <div id="sd-meta" style="font-size:0.78rem;color:#666;margin-top:3px"></div>
      </div>
      <button onclick="document.getElementById('session-detail-modal').classList.remove('open')" style="background:none;border:none;color:#555;cursor:pointer;font-size:1.2rem;padding:0 0 0 12px">✕</button>
    </div>
    <hr style="border-color:#1e1e1e;margin:12px 0">
    <div id="sd-body" style="max-height:60vh;overflow-y:auto"></div>
  </div>
</div>

<!-- ── Rest Timer Banner ── -->
<div class="rest-banner" id="rest-banner">
  <div>
    <div style="font-size:0.7rem;color:#888;text-transform:uppercase;letter-spacing:1px">Rest</div>
    <div class="rest-time" id="rest-time">1:30</div>
  </div>
  <div style="display:flex;flex-direction:column;gap:6px">
    <button onclick="adjustRest(30)"  style="padding:3px 10px;background:#1a2a1a;border:1px solid #2a4a2a;color:#2ecc71;border-radius:6px;cursor:pointer;font-size:0.8rem">+30s</button>
    <button onclick="adjustRest(-30)" style="padding:3px 10px;background:#2a1a1a;border:1px solid #4a2a2a;color:#e74c3c;border-radius:6px;cursor:pointer;font-size:0.8rem">-30s</button>
  </div>
  <button onclick="stopRest()" style="background:none;border:none;color:#555;cursor:pointer;font-size:1.2rem;padding:0 4px">✕</button>
</div>

<script>
// ── State ──────────────────────────────────────────────────────────────────
let sessionId    = localStorage.getItem('activeSessionId') ? parseInt(localStorage.getItem('activeSessionId')) : null;
let sessionStart = localStorage.getItem('activeSessionStart') ? parseInt(localStorage.getItem('activeSessionStart')) : null;
let exercises    = [];       // [{ name, id, order, sets:[{id,reps,weight,unit}] }]
let allExercises = [];       // full library from server
let selectedType = 'strength';
let selectedEffort = 3;
let timerInterval = null;
let restInterval  = null;
let restRemaining = 0;

// Builder state
let templateExercises = []; // [{ exerciseId, exerciseName, defaultSets, defaultReps }]
let builderSelectedCat = '';

// ── Init ───────────────────────────────────────────────────────────────────
(async () => {
  await loadExerciseLibrary();
  if (sessionId) await resumeSession();
})();

async function loadExerciseLibrary() {
  const r = await fetch('/workout/api/exercises');
  const j = await r.json();
  if (j.success) allExercises = j.data;
  renderExerciseList('');
}

async function resumeSession() {
  const r = await fetch('/workout/api/session/' + sessionId);
  const j = await r.json();
  if (!j.success || j.data.status === 'finished') {
    clearSession(); return;
  }
  const s = j.data;
  sessionStart = sessionStart || Date.now();
  exercises = [];
  const byOrder = {};
  for (const set of (s.sets || [])) {
    if (!byOrder[set.exerciseOrder]) byOrder[set.exerciseOrder] = { name: set.exerciseName, id: set.exerciseId, order: set.exerciseOrder, sets: [] };
    byOrder[set.exerciseOrder].sets.push({ id: set.id, reps: set.reps, weight: set.weight, unit: set.weightUnit || 'lbs' });
  }
  exercises = Object.values(byOrder).sort((a,b) => a.order - b.order);
  showActiveSession(s.type, s.title || s.type);
  renderExercises();
}

function clearSession() {
  sessionId = null; sessionStart = null; exercises = [];
  localStorage.removeItem('activeSessionId');
  localStorage.removeItem('activeSessionStart');
  clearInterval(timerInterval);
}

// ── Timer ──────────────────────────────────────────────────────────────────
function startTimer() {
  clearInterval(timerInterval);
  timerInterval = setInterval(() => {
    if (!sessionStart) return;
    const elapsed = Math.floor((Date.now() - sessionStart) / 1000);
    const m = String(Math.floor(elapsed/60)).padStart(2,'0');
    const s = String(elapsed%60).padStart(2,'0');
    document.getElementById('session-timer').textContent = m+':'+s;
  }, 1000);
}

// ── Start workflow ─────────────────────────────────────────────────────────
function openStartModal()  { document.getElementById('start-modal').classList.add('open'); }
function closeStartModal() { document.getElementById('start-modal').classList.remove('open'); }
function startWorkout(type, title) { selectedType=type||'strength'; document.getElementById('start-title').value=title||''; openStartModal(); }

document.getElementById('type-tabs').addEventListener('click', e => {
  const tab = e.target.closest('[data-type]');
  if (!tab) return;
  document.querySelectorAll('#type-tabs .cat-tab').forEach(t => t.classList.remove('active'));
  tab.classList.add('active');
  selectedType = tab.dataset.type;
});

async function confirmStart(preloadedExercises) {
  const title = document.getElementById('start-title').value.trim();
  const r = await fetch('/workout/api/session', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ type: selectedType, title, date: new Date().toISOString().split('T')[0] }) });
  const j = await r.json();
  if (!j.success) return;
  sessionId    = j.data.id;
  sessionStart = Date.now();
  localStorage.setItem('activeSessionId',    sessionId);
  localStorage.setItem('activeSessionStart', sessionStart);
  exercises = [];
  closeStartModal();
  showActiveSession(selectedType, title || selectedType);
  // Pre-load exercises from template if any
  if (preloadedExercises && preloadedExercises.length) {
    preloadedExercises.forEach((ex, i) => {
      exercises.push({ id: ex.exerciseId || null, name: ex.exerciseName, order: i, sets: [] });
    });
  }
  renderExercises();
}

function showActiveSession(type, title) {
  document.getElementById('no-session').style.display    = 'none';
  document.getElementById('active-session').style.display = 'block';
  const tagEl = document.getElementById('session-type-label');
  tagEl.textContent = type;
  tagEl.className   = 'tag tag-' + type;
  document.getElementById('session-title-label').textContent = title || type;
  startTimer();
}

// ── Exercise modal (active session) ───────────────────────────────────────
function openExerciseModal()  { filterExercises(); document.getElementById('exercise-modal').classList.add('open'); }
function closeExerciseModal() { document.getElementById('exercise-modal').classList.remove('open'); document.getElementById('ex-search').value = ''; }

let selectedCat = '';
document.getElementById('ex-cat-tabs').addEventListener('click', e => {
  const tab = e.target.closest('[data-cat]');
  if (!tab) return;
  document.querySelectorAll('#ex-cat-tabs .cat-tab').forEach(t => t.classList.remove('active'));
  tab.classList.add('active');
  selectedCat = tab.dataset.cat;
  filterExercises();
});

function filterExercises() {
  const q = document.getElementById('ex-search').value.toLowerCase();
  renderExerciseList(q);
}

function renderExerciseList(q) {
  const list = document.getElementById('ex-list');
  if (!list) return;
  let filtered = allExercises;
  if (selectedCat) filtered = filtered.filter(e => e.category === selectedCat);
  if (q) filtered = filtered.filter(e => e.name.toLowerCase().includes(q));
  list.innerHTML = filtered.slice(0,40).map(e =>
    `<li onclick="pickExercise(${e.id},'${e.name.replace(/'/g,"\\'")}','${e.category}')">
      <div class="ex-name">${e.name}</div>
      <div class="ex-tags">${e.equipment} · ${(e.primaryMuscles||[]).slice(0,3).join(', ')}</div>
    </li>`
  ).join('');
}

function pickExercise(id, name) {
  addExerciseToSession(id, name);
  closeExerciseModal();
}

function addCustomExercise() {
  const name = document.getElementById('custom-ex-name').value.trim();
  if (!name) return;
  addExerciseToSession(null, name);
  document.getElementById('custom-ex-name').value = '';
  closeExerciseModal();
}

function addExerciseToSession(id, name) {
  const order = exercises.length;
  exercises.push({ id, name, order, sets: [] });
  renderExercises();
}

// ── Exercises render ───────────────────────────────────────────────────────
function renderExercises() {
  const container = document.getElementById('exercises-container');
  if (!exercises.length) { container.innerHTML = ''; return; }
  container.innerHTML = exercises.map((ex, ei) => `
    <div class="exercise-block" id="ex-block-${ei}">
      <div class="exercise-block-header">
        <div>
          <div class="exercise-block-name">${ex.name}</div>
          <div class="exercise-block-meta">${ex.sets.length} set${ex.sets.length!==1?'s':''} logged</div>
        </div>
        <button onclick="removeExercise(${ei})" style="background:none;border:none;color:#444;cursor:pointer;font-size:0.85rem" title="Remove">✕</button>
      </div>
      <div style="padding:6px 14px 0;display:grid;grid-template-columns:32px 1fr 1fr 40px;gap:6px;font-size:0.72rem;color:#555">
        <span style="text-align:center">Set</span><span>Reps</span><span>Weight</span><span></span>
      </div>
      ${ex.sets.map((s,si) => `
        <div class="set-row" id="set-row-${ei}-${si}">
          <span class="set-num">${si+1}</span>
          <input class="set-input" type="number" min="0" value="${s.reps||''}" placeholder="reps" onchange="updateSetField(${ei},${si},'reps',this.value)">
          <div style="display:flex;gap:4px;align-items:center">
            <input class="set-input" type="number" min="0" step="2.5" value="${s.weight||''}" placeholder="lbs" onchange="updateSetField(${ei},${si},'weight',this.value)" style="flex:1">
            <select onchange="updateSetField(${ei},${si},'unit',this.value)" style="background:#1a1a1a;border:1px solid #2a2a2a;border-radius:6px;padding:5px 4px;color:#888;font-size:0.72rem">
              <option${s.unit==='lbs'?' selected':''}>lbs</option>
              <option${s.unit==='kg'?' selected':''}>kg</option>
            </select>
          </div>
          <button class="btn-del-set" onclick="deleteSet(${ei},${si})" title="Delete">🗑</button>
        </div>
      `).join('')}
      <button class="btn-add-set" onclick="addSet(${ei})">+ Add Set</button>
    </div>
  `).join('');
}

async function addSet(ei) {
  if (!sessionId) return;
  const ex    = exercises[ei];
  const setNum = ex.sets.length + 1;
  const prev   = ex.sets[ex.sets.length - 1];
  const r = await fetch(`/workout/api/session/${sessionId}/set`, {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ exerciseName: ex.name, exerciseId: ex.id, exerciseOrder: ex.order, setNumber: setNum, reps: prev?.reps || null, weight: prev?.weight || null, weightUnit: prev?.unit || 'lbs' }),
  });
  const j = await r.json();
  if (j.success) {
    ex.sets.push({ id: j.data.id, reps: j.data.reps, weight: j.data.weight, unit: j.data.weightUnit || 'lbs' });
    renderExercises();
    startRestTimer(90);
  }
}

async function updateSetField(ei, si, field, val) {
  const set = exercises[ei].sets[si];
  if (!set) return;
  if (field === 'reps')   set.reps   = parseInt(val) || null;
  if (field === 'weight') set.weight = parseFloat(val) || null;
  if (field === 'unit')   set.unit   = val;
  // Update persisted in memory; full save on finish
}

async function deleteSet(ei, si) {
  const set = exercises[ei].sets[si];
  if (set?.id) await fetch(`/workout/api/set/${set.id}`, { method: 'DELETE' });
  exercises[ei].sets.splice(si, 1);
  renderExercises();
}

function removeExercise(ei) {
  exercises[ei].sets.forEach(s => { if(s.id) fetch(`/workout/api/set/${s.id}`,{method:'DELETE'}); });
  exercises.splice(ei, 1);
  exercises.forEach((ex, i) => ex.order = i);
  renderExercises();
}

// ── Finish ─────────────────────────────────────────────────────────────────
function openFinishModal() { document.getElementById('finish-modal').classList.add('open'); }
function closeFinishModal(){ document.getElementById('finish-modal').classList.remove('open'); }

document.getElementById('effort-row').addEventListener('click', e => {
  const btn = e.target.closest('[data-val]');
  if (!btn) return;
  document.querySelectorAll('.effort-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  selectedEffort = parseInt(btn.dataset.val);
});

document.getElementById('save-as-template-check').addEventListener('change', e => {
  document.getElementById('template-name-input').style.display = e.target.checked ? 'block' : 'none';
});

async function confirmFinish() {
  if (!sessionId) return;
  const duration = sessionStart ? Math.round((Date.now() - sessionStart) / 60000) : null;
  const notes    = document.getElementById('finish-notes').value.trim();
  await fetch('/workout/api/session/' + sessionId, {
    method: 'PATCH', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ status:'finished', effort: selectedEffort, duration, notes }),
  });
  // Save as template if checked
  const saveCheck = document.getElementById('save-as-template-check').checked;
  if (saveCheck && exercises.length) {
    const tplName = document.getElementById('template-name-input').value.trim() ||
                    document.getElementById('session-title-label').textContent ||
                    'My Workout';
    const tplType = document.getElementById('session-type-label').textContent || 'strength';
    const tplExercises = exercises.map(ex => ({ exerciseId: ex.id || null, exerciseName: ex.name, defaultSets: ex.sets.length || 3, defaultReps: null }));
    await fetch('/workout/api/templates', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ name: tplName, type: tplType, exercises: tplExercises }),
    });
  }
  clearSession();
  stopRest();
  window.location.reload();
}

async function discardSession() {
  if (!sessionId || !confirm('Discard this workout?')) return;
  await fetch('/workout/api/session/' + sessionId, { method: 'DELETE' });
  clearSession(); stopRest();
  window.location.reload();
}

async function viewSession(id) {
  const r = await fetch('/workout/api/session/' + id);
  const j = await r.json();
  if (!j.success) return;
  const s = j.data;
  const byOrder = {};
  for (const set of (s.sets||[])) {
    if (!byOrder[set.exerciseOrder]) byOrder[set.exerciseOrder] = { name: set.exerciseName, sets: [] };
    byOrder[set.exerciseOrder].sets.push(set);
  }
  const exercises = Object.values(byOrder);
  const modal = document.getElementById('session-detail-modal');
  document.getElementById('sd-title').textContent = (s.title || s.type) + (s.duration ? ` · ${s.duration} min` : '');
  document.getElementById('sd-meta').textContent = s.date + (s.effort ? ` · RPE ${'★'.repeat(s.effort)}` : '') + (s.notes ? ` · ${s.notes}` : '');
  document.getElementById('sd-body').innerHTML = exercises.map(ex => `
    <div style="margin-bottom:12px">
      <div style="font-weight:600;color:#e8e8e8;margin-bottom:4px">${ex.name}</div>
      <table style="width:100%;font-size:0.82rem;border-collapse:collapse">
        <tr style="color:#555;font-size:0.75rem"><td style="padding:2px 8px 4px 0">Set</td><td style="padding:2px 8px 4px 0">Reps</td><td style="padding:2px 0 4px">Weight</td></tr>
        ${ex.sets.map((s,i) => `
          <tr style="border-top:1px solid #1a1a1a">
            <td style="padding:5px 8px 5px 0;color:#555">${i+1}</td>
            <td style="padding:5px 8px 5px 0;color:#ccc">${s.duration ? s.duration+'s' : (s.reps || '—')}</td>
            <td style="padding:5px 0;color:#ccc">${s.weight ? s.weight+(s.weightUnit||'lbs') : 'BW'}</td>
          </tr>`).join('')}
      </table>
    </div>`).join('') || '<p style="color:#555">No sets recorded.</p>';
  modal.classList.add('open');
}

// ── Template Builder ───────────────────────────────────────────────────────
function openTemplateBuilder() {
  templateExercises = [];
  document.getElementById('builder-name').value = '';
  document.getElementById('builder-type').value = 'strength';
  renderBuilderExercises();
  document.getElementById('builder-modal').classList.add('open');
}

function closeTemplateBuilder() {
  document.getElementById('builder-modal').classList.remove('open');
}

function renderBuilderExercises() {
  const container = document.getElementById('builder-exercises');
  if (!templateExercises.length) {
    container.innerHTML = '<p style="color:#555;font-size:0.85rem;text-align:center;padding:12px 0">No exercises added yet.</p>';
    return;
  }
  container.innerHTML = templateExercises.map((ex, i) => `
    <div class="builder-ex-card">
      <div>
        <div class="builder-ex-name">${ex.exerciseName}</div>
        <div class="builder-ex-meta">
          <input type="number" min="1" max="20" value="${ex.defaultSets||3}" placeholder="sets" style="width:46px;background:#1a1a1a;border:1px solid #2a2a2a;border-radius:4px;padding:3px 6px;color:#e8e8e8;font-size:0.72rem" onchange="updateTplEx(${i},'sets',this.value)"> sets ×
          <input type="number" min="1" max="100" value="${ex.defaultReps||''}" placeholder="reps" style="width:46px;background:#1a1a1a;border:1px solid #2a2a2a;border-radius:4px;padding:3px 6px;color:#e8e8e8;font-size:0.72rem" onchange="updateTplEx(${i},'reps',this.value)"> reps
        </div>
      </div>
      <button onclick="removeTplEx(${i})" style="background:none;border:none;color:#444;cursor:pointer;font-size:0.85rem;padding:4px 6px">✕</button>
    </div>
  `).join('');
}

function updateTplEx(i, field, val) {
  if (field === 'sets') templateExercises[i].defaultSets = parseInt(val) || null;
  if (field === 'reps') templateExercises[i].defaultReps = parseInt(val) || null;
}

function removeTplEx(i) {
  templateExercises.splice(i, 1);
  renderBuilderExercises();
}

async function saveTemplate() {
  const name = document.getElementById('builder-name').value.trim();
  const type = document.getElementById('builder-type').value;
  if (!name) { alert('Please enter a template name.'); return; }
  if (!templateExercises.length) { alert('Add at least one exercise.'); return; }
  const r = await fetch('/workout/api/templates', {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ name, type, exercises: templateExercises }),
  });
  const j = await r.json();
  if (j.success) { closeTemplateBuilder(); window.location.reload(); }
}

// ── Builder Exercise Picker ────────────────────────────────────────────────
function openBuilderExPicker() {
  builderSelectedCat = '';
  document.getElementById('bex-search').value = '';
  document.querySelectorAll('#bex-cat-tabs .cat-tab').forEach((t,i) => { t.classList.toggle('active', i===0); });
  renderBuilderExList('');
  document.getElementById('builder-ex-modal').classList.add('open');
}

function closeBuilderExPicker() {
  document.getElementById('builder-ex-modal').classList.remove('open');
}

document.getElementById('bex-cat-tabs').addEventListener('click', e => {
  const tab = e.target.closest('[data-cat]');
  if (!tab) return;
  document.querySelectorAll('#bex-cat-tabs .cat-tab').forEach(t => t.classList.remove('active'));
  tab.classList.add('active');
  builderSelectedCat = tab.dataset.cat;
  filterBuilderExercises();
});

function filterBuilderExercises() {
  const q = document.getElementById('bex-search').value.toLowerCase();
  renderBuilderExList(q);
}

function renderBuilderExList(q) {
  const list = document.getElementById('bex-list');
  if (!list) return;
  let filtered = allExercises;
  if (builderSelectedCat) filtered = filtered.filter(e => e.category === builderSelectedCat);
  if (q) filtered = filtered.filter(e => e.name.toLowerCase().includes(q));
  list.innerHTML = filtered.slice(0,40).map(e =>
    `<li onclick="pickBuilderExercise(${e.id},'${e.name.replace(/'/g,"\\'")}',${e.defaultSets||3},${e.defaultReps||null})">
      <div class="ex-name">${e.name}</div>
      <div class="ex-tags">${e.equipment} · ${(e.primaryMuscles||[]).slice(0,3).join(', ')}</div>
    </li>`
  ).join('');
}

function pickBuilderExercise(id, name, defaultSets, defaultReps) {
  templateExercises.push({ exerciseId: id, exerciseName: name, defaultSets: defaultSets || 3, defaultReps: defaultReps || null });
  closeBuilderExPicker();
  renderBuilderExercises();
}

function addCustomToBuilder() {
  const name = document.getElementById('bex-custom').value.trim();
  if (!name) return;
  templateExercises.push({ exerciseId: null, exerciseName: name, defaultSets: 3, defaultReps: null });
  document.getElementById('bex-custom').value = '';
  closeBuilderExPicker();
  renderBuilderExercises();
}

// ── Load Template ──────────────────────────────────────────────────────────
async function loadTemplate(id) {
  if (sessionId) {
    if (!confirm('You have an active workout. Start a new one with this template?')) return;
    await fetch('/workout/api/session/' + sessionId, { method: 'DELETE' });
    clearSession(); stopRest();
  }
  const r = await fetch('/workout/api/templates');
  const j = await r.json();
  if (!j.success) return;
  const tpl = j.data.find(t => t.id === id);
  if (!tpl) return;
  // Set type tab in modal
  selectedType = tpl.type || 'strength';
  document.querySelectorAll('#type-tabs .cat-tab').forEach(t => {
    t.classList.toggle('active', t.dataset.type === selectedType);
  });
  document.getElementById('start-title').value = tpl.name;
  // Confirm start with preloaded exercises
  await confirmStart(tpl.exercises);
}

async function deleteTemplate(id) {
  if (!confirm('Delete this workout template?')) return;
  await fetch(`/workout/api/templates/${id}`, { method: 'DELETE' });
  const card = document.getElementById('tpl-' + id);
  if (card) card.remove();
}

// ── Rest timer ─────────────────────────────────────────────────────────────
function startRestTimer(seconds) {
  restRemaining = seconds;
  document.getElementById('rest-banner').classList.add('show');
  clearInterval(restInterval);
  restInterval = setInterval(() => {
    restRemaining--;
    if (restRemaining <= 0) { stopRest(); return; }
    const m = Math.floor(restRemaining/60);
    const s = restRemaining%60;
    document.getElementById('rest-time').textContent = m+':'+(s<10?'0':'')+s;
  }, 1000);
  document.getElementById('rest-time').textContent = Math.floor(seconds/60)+':'+(seconds%60 < 10 ? '0' : '')+seconds%60;
}
function stopRest()   { clearInterval(restInterval); document.getElementById('rest-banner').classList.remove('show'); }
function adjustRest(d){ restRemaining = Math.max(0, restRemaining + d); if(restRemaining<=0) stopRest(); }
</script>
</body>
</html>
