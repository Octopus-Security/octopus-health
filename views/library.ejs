<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/theme.css">
  <style>
    /* ── Layout ─────────────────────────── */
    .filter-bar { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px; align-items:center; }
    .filter-bar input { flex:1; min-width:180px; background:#0d0d0d; border:1px solid #2a2a2a; border-radius:8px; padding:8px 14px; color:#e8e8e8; font-size:0.9rem; }
    .filter-bar input:focus { outline:none; border-color:#2ecc71; }
    .filter-bar select { background:#0d0d0d; border:1px solid #2a2a2a; border-radius:8px; padding:8px 12px; color:#e8e8e8; font-size:0.9rem; }
    .cat-tabs { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:16px; }
    .cat-tab  { padding:5px 14px; border-radius:20px; border:1px solid #2a2a2a; background:#0d0d0d; color:#888; font-size:0.8rem; cursor:pointer; transition:all 0.15s; }
    .cat-tab.active { background:#1a2a1a; border-color:#2ecc71; color:#2ecc71; }
    .lib-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:16px; }
    .count-badge { font-size:0.8rem; color:#555; }

    /* ── Category accent colours ─────────── */
    :root {
      --c-strength:    #5b9bd5;
      --c-conditioning:#2ecc71;
      --c-cardio:      #1abc9c;
      --c-mma:         #e07b54;
      --c-bjj:         #9b59b6;
      --c-muay_thai:   #e74c3c;
      --c-recovery:    #95a5a6;
    }
    /* ── Card ────────────────────────────── */
    .ex-card {
      background:#0d0d0d;
      border:1px solid #1e1e1e;
      border-radius:12px;
      overflow:hidden;
      display:flex;
      flex-direction:column;
      transition:border-color 0.15s, transform 0.1s;
    }
    .ex-card:hover { border-color:#2a2a2a; transform:translateY(-1px); }
    /* coloured top bar driven by data-cat */
    .ex-card[data-cat="strength"]    { border-top:3px solid var(--c-strength); }
    .ex-card[data-cat="conditioning"]{ border-top:3px solid var(--c-conditioning); }
    .ex-card[data-cat="cardio"]      { border-top:3px solid var(--c-cardio); }
    .ex-card[data-cat="mma"]         { border-top:3px solid var(--c-mma); }
    .ex-card[data-cat="bjj"]         { border-top:3px solid var(--c-bjj); }
    .ex-card[data-cat="muay_thai"]   { border-top:3px solid var(--c-muay_thai); }
    .ex-card[data-cat="recovery"]    { border-top:3px solid var(--c-recovery); }

    /* ── Media placeholder / future animation area ── */
    .ex-media {
      position:relative;
      width:100%;
      height:120px;
      background: linear-gradient(135deg, #111 0%, #0a0a0a 100%);
      display:flex;
      align-items:center;
      justify-content:center;
      overflow:hidden;
      border-bottom:1px solid #1a1a1a;
    }
    .ex-media-icon {
      font-size:2.8rem;
      opacity:0.18;
      user-select:none;
      pointer-events:none;
    }
    .ex-media-label {
      position:absolute;
      bottom:6px;
      right:10px;
      font-size:0.6rem;
      color:#333;
      letter-spacing:0.5px;
      text-transform:uppercase;
    }
    .ex-video-btn {
      position:absolute;
      inset:0;
      display:flex;
      align-items:center;
      justify-content:center;
      background:rgba(0,0,0,0.4);
      text-decoration:none;
      transition:background 0.15s;
    }
    .ex-video-btn:hover { background:rgba(0,0,0,0.6); }
    .play-circle {
      width:44px; height:44px;
      border-radius:50%;
      background:rgba(231,76,60,0.85);
      display:flex; align-items:center; justify-content:center;
      font-size:1.1rem;
      color:#fff;
      box-shadow:0 2px 12px rgba(0,0,0,0.6);
      transition:transform 0.15s;
    }
    .ex-video-btn:hover .play-circle { transform:scale(1.1); }

    /* ── Card body ───────────────────────── */
    .ex-card-body { padding:12px 14px 10px; flex:1; }
    .ex-card-name { font-weight:600; color:#e8e8e8; font-size:0.95rem; line-height:1.3; margin-bottom:6px; }
    .ex-equip-row { display:flex; align-items:center; gap:6px; margin-bottom:8px; }
    .tag { display:inline-block; padding:2px 8px; border-radius:4px; font-size:0.67rem; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; }
    .tag-strength    { background:#1a2a4a; color:var(--c-strength); }
    .tag-mma         { background:#2a1a1a; color:var(--c-mma); }
    .tag-bjj         { background:#1a1a2a; color:var(--c-bjj); }
    .tag-muay_thai   { background:#2a1a1a; color:var(--c-muay_thai); }
    .tag-conditioning{ background:#1a2a1a; color:var(--c-conditioning); }
    .tag-cardio      { background:#1a2520; color:var(--c-cardio); }
    .tag-recovery    { background:#252020; color:var(--c-recovery); }
    .tag-equip       { background:#161616; color:#555; border:1px solid #222; }
    .tag-custom      { background:#2a1a2a; color:#e91e8c; }

    /* muscles */
    .muscle-row { display:flex; flex-wrap:wrap; gap:4px; margin-bottom:8px; }
    .muscle-chip {
      font-size:0.67rem; padding:2px 7px; border-radius:3px;
      background:#161616; color:#777; border:1px solid #222;
    }
    .muscle-chip.primary { color:#bbb; border-color:#333; background:#1a1a1a; }

    /* schematic badges */
    .schema-row { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:10px; }
    .schema-badge {
      display:flex; align-items:center; gap:4px;
      background:#151515; border:1px solid #222; border-radius:6px;
      padding:3px 8px; font-size:0.75rem; color:#aaa;
    }
    .schema-badge .lbl { font-size:0.65rem; color:#555; text-transform:uppercase; letter-spacing:0.4px; }

    /* instructions */
    .ex-instructions-wrap { overflow:hidden; max-height:0; transition:max-height 0.2s ease; }
    .ex-instructions-wrap.open { max-height:200px; }
    .ex-instructions { font-size:0.78rem; color:#777; line-height:1.55; padding-top:4px; border-top:1px solid #1a1a1a; }
    .btn-details {
      background:none; border:none; cursor:pointer; color:#444;
      font-size:0.72rem; padding:0; transition:color 0.1s;
      display:inline-flex; align-items:center; gap:3px;
    }
    .btn-details:hover { color:#2ecc71; }

    /* ── Modal ───────────────────────────── */
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:100; align-items:center; justify-content:center; }
    .modal-overlay.open { display:flex; }
    .modal { background:#111; border:1px solid #222; border-radius:14px; padding:24px; width:min(480px,95vw); max-height:85vh; overflow-y:auto; }
    .modal h3 { color:#e8e8e8; margin-bottom:16px; }
    .form-group { margin-bottom:12px; }
    .form-group label { display:block; font-size:0.8rem; color:#888; margin-bottom:4px; }
    .form-group input, .form-group select, .form-group textarea { width:100%; background:#0d0d0d; border:1px solid #2a2a2a; border-radius:8px; padding:8px 12px; color:#e8e8e8; font-size:0.9rem; box-sizing:border-box; }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline:none; border-color:#2ecc71; }
    .form-group textarea { resize:vertical; min-height:70px; }
  </style>
</head>
<body>
<nav>
  <div class="container">
    <h1>🏥 Health Tracker</h1>
    <div class="nav-links">
      <a href="/">Dashboard</a>
      <a href="/workout">Workout</a>
      <a href="/library" style="color:#2ecc71">Library</a>
      <a href="/timers">Timers</a>
      <a href="/plans">Plans</a>
      <a href="/weight">Weight</a>
      <a href="/exercise">Exercise</a>
      <a href="/meals">Meals</a>
      <a href="/goals">Goals</a>
      <a href="/planner">Planner</a>
      <a href="/competitions">Competitions</a>
      <a href="/accountability">Accountability</a>
      <a href="/settings">Settings</a>
      <a href="/logout">Logout</a>
    </div>
  </div>
</nav>

<div class="container" style="padding-top:24px">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h2 style="margin:0">📚 Exercise Library</h2>
    <button onclick="document.getElementById('add-modal').classList.add('open')" class="btn">+ Custom Exercise</button>
  </div>

  <div class="filter-bar">
    <input type="text" id="search-input" placeholder="Search exercises..." oninput="filterExercises()">
    <select id="equip-filter" onchange="filterExercises()">
      <option value="">All Equipment</option>
      <option value="barbell">Barbell</option>
      <option value="dumbbell">Dumbbell</option>
      <option value="cable_machine">Cable Machine</option>
      <option value="machine">Machine</option>
      <option value="bodyweight">Bodyweight</option>
      <option value="bag">Bag</option>
      <option value="pads">Pads</option>
      <option value="cardio_machine">Cardio Machine</option>
      <option value="none">None</option>
    </select>
    <select id="muscle-filter" onchange="filterExercises()">
      <option value="">All Muscles</option>
      <option value="chest">Chest</option>
      <option value="back">Back</option>
      <option value="shoulders">Shoulders</option>
      <option value="biceps">Biceps</option>
      <option value="triceps">Triceps</option>
      <option value="forearms">Forearms</option>
      <option value="core">Core</option>
      <option value="quads">Quads</option>
      <option value="hamstrings">Hamstrings</option>
      <option value="glutes">Glutes</option>
      <option value="calves">Calves</option>
      <option value="full_body">Full Body</option>
    </select>
  </div>

  <div class="cat-tabs" id="cat-tabs">
    <button class="cat-tab active" data-cat="">All</button>
    <button class="cat-tab" data-cat="strength">Strength</button>
    <button class="cat-tab" data-cat="conditioning">Conditioning</button>
    <button class="cat-tab" data-cat="cardio">Cardio</button>
    <button class="cat-tab" data-cat="mma">MMA</button>
    <button class="cat-tab" data-cat="bjj">BJJ</button>
    <button class="cat-tab" data-cat="muay_thai">Muay Thai</button>
    <button class="cat-tab" data-cat="recovery">Recovery</button>
  </div>

  <div style="margin-bottom:12px">
    <span class="count-badge" id="count-label"></span>
  </div>

  <div class="lib-grid" id="lib-grid"></div>
</div>

<!-- Add custom exercise modal -->
<div class="modal-overlay" id="add-modal">
  <div class="modal">
    <h3>+ Custom Exercise</h3>
    <form id="add-form">
      <div class="form-group">
        <label>Name *</label>
        <input type="text" name="name" required placeholder="e.g. Kettlebell Swing">
      </div>
      <div class="form-group">
        <label>Category *</label>
        <select name="category" required>
          <option value="strength">Strength</option>
          <option value="conditioning">Conditioning</option>
          <option value="cardio">Cardio</option>
          <option value="mma">MMA</option>
          <option value="bjj">BJJ</option>
          <option value="muay_thai">Muay Thai</option>
          <option value="recovery">Recovery</option>
        </select>
      </div>
      <div class="form-group">
        <label>Equipment *</label>
        <select name="equipment" required>
          <option value="barbell">Barbell</option>
          <option value="dumbbell">Dumbbell</option>
          <option value="cable_machine">Cable Machine</option>
          <option value="machine">Machine</option>
          <option value="bodyweight">Bodyweight</option>
          <option value="bag">Bag</option>
          <option value="pads">Pads</option>
          <option value="cardio_machine">Cardio Machine</option>
          <option value="none">None</option>
        </select>
      </div>
      <div class="form-group">
        <label>Primary Muscles (comma separated)</label>
        <input type="text" name="primaryMuscles" placeholder="e.g. glutes, hamstrings">
      </div>
      <div class="form-group">
        <label>Instructions</label>
        <textarea name="instructions" placeholder="How to perform the exercise..."></textarea>
      </div>
      <div class="form-group">
        <label>Video URL (optional)</label>
        <input type="text" name="videoUrl" placeholder="https://...">
      </div>
      <div style="display:flex;gap:10px;margin-top:16px">
        <button type="submit" class="btn btn-green" style="flex:1">Save</button>
        <button type="button" onclick="document.getElementById('add-modal').classList.remove('open')" class="btn" style="flex:1">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
const ALL_EXERCISES = <%- JSON.stringify(exercises) %>;
let activeCat = '';

// Category tabs
document.querySelectorAll('.cat-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.cat-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeCat = btn.dataset.cat;
    filterExercises();
  });
});

function filterExercises() {
  const q      = document.getElementById('search-input').value.toLowerCase();
  const equip  = document.getElementById('equip-filter').value;
  const muscle = document.getElementById('muscle-filter').value;

  let list = ALL_EXERCISES;
  if (activeCat) list = list.filter(e => e.category === activeCat);
  if (equip)     list = list.filter(e => e.equipment === equip);
  if (muscle)    list = list.filter(e => e.primaryMuscles.includes(muscle) || e.secondaryMuscles.includes(muscle));
  if (q)         list = list.filter(e => e.name.toLowerCase().includes(q));

  renderGrid(list);
}

// Category → emoji icon for the media placeholder
const CAT_ICON = {
  strength:'🏋️', conditioning:'⚡', cardio:'🏃', mma:'🥊',
  bjj:'🥋', muay_thai:'🦵', recovery:'🧘', default:'💪'
};

function renderGrid(list) {
  document.getElementById('count-label').textContent = `${list.length} exercise${list.length !== 1 ? 's' : ''}`;
  const grid = document.getElementById('lib-grid');
  grid.innerHTML = list.map(e => {
    const catClass   = 'tag-' + e.category;
    const equipLabel = (e.equipment || '').replace(/_/g,' ');
    const icon       = CAT_ICON[e.category] || CAT_ICON.default;
    const hasInstr   = e.instructions && e.instructions.trim();
    const hasVideo   = e.videoUrl && e.videoUrl.trim();
    const isCustom   = e.isCustom;

    // sets × reps / duration badges
    let schemaBadges = '';
    if (e.defaultSets)    schemaBadges += `<div class="schema-badge"><span class="lbl">sets</span> ${e.defaultSets}</div>`;
    if (e.defaultReps)    schemaBadges += `<div class="schema-badge"><span class="lbl">reps</span> ${e.defaultReps}</div>`;
    if (e.defaultDuration) {
      const d = e.defaultDuration;
      const fmt = d >= 60 ? `${Math.floor(d/60)}m${d%60?` ${d%60}s`:''}` : `${d}s`;
      schemaBadges += `<div class="schema-badge"><span class="lbl">duration</span> ${fmt}</div>`;
    }

    // muscle chips
    const primChips = (e.primaryMuscles||[]).map(m =>
      `<span class="muscle-chip primary">${m.replace(/_/g,' ')}</span>`).join('');
    const secChips  = (e.secondaryMuscles||[]).filter(m => !e.primaryMuscles.includes(m)).map(m =>
      `<span class="muscle-chip">${m.replace(/_/g,' ')}</span>`).join('');

    // media area — play button overlay if video, else placeholder
    const mediaInner = hasVideo
      ? `<a href="${escHtml(e.videoUrl)}" target="_blank" rel="noopener" class="ex-video-btn" title="Watch on YouTube">
           <div class="play-circle">▶</div>
         </a>
         <span class="ex-media-icon">${icon}</span>`
      : `<span class="ex-media-icon">${icon}</span>
         <span class="ex-media-label">animation coming soon</span>`;

    return `
<div class="ex-card" data-id="${e.id}" data-cat="${e.category}">
  <div class="ex-media">${mediaInner}</div>
  <div class="ex-card-body">
    <div class="ex-card-name">${escHtml(e.name)}</div>
    <div class="ex-equip-row">
      <span class="tag ${catClass}">${e.category.replace(/_/g,' ')}</span>
      <span class="tag tag-equip">${equipLabel}</span>
      ${isCustom ? '<span class="tag tag-custom">custom</span>' : ''}
    </div>
    ${schemaBadges ? `<div class="schema-row">${schemaBadges}</div>` : ''}
    ${(primChips||secChips) ? `<div class="muscle-row">${primChips}${secChips}</div>` : ''}
    ${hasInstr ? `
      <div class="ex-instructions-wrap" id="instr-wrap-${e.id}">
        <div class="ex-instructions">${escHtml(e.instructions)}</div>
      </div>
      <button class="btn-details" onclick="toggleInstructions(${e.id})" id="expand-${e.id}">▼ show instructions</button>
    ` : ''}
  </div>
</div>`;
  }).join('');
}

function toggleInstructions(id) {
  const wrap = document.getElementById('instr-wrap-' + id);
  const btn  = document.getElementById('expand-' + id);
  if (!wrap) return;
  wrap.classList.toggle('open');
  btn.textContent = wrap.classList.contains('open') ? '▲ hide instructions' : '▼ show instructions';
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// Custom exercise form
document.getElementById('add-form').addEventListener('submit', async e => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const primaryMuscles = (fd.get('primaryMuscles') || '').split(',').map(s => s.trim()).filter(Boolean);
  const body = {
    name:          fd.get('name'),
    category:      fd.get('category'),
    equipment:     fd.get('equipment'),
    primaryMuscles,
    instructions:  fd.get('instructions') || null,
    videoUrl:      fd.get('videoUrl')     || null,
  };
  try {
    const token = localStorage.getItem('authToken');
    const headers = { 'Content-Type': 'application/json' };
    if (token) headers['Authorization'] = 'Bearer ' + token;
    const r = await fetch('/api/workout/exercises', { method:'POST', headers, body: JSON.stringify(body) });
    const data = await r.json();
    if (data.success) {
      const newEx = { ...data.data, primaryMuscles: body.primaryMuscles, secondaryMuscles: [] };
      ALL_EXERCISES.unshift(newEx);
      document.getElementById('add-modal').classList.remove('open');
      e.target.reset();
      filterExercises();
    } else {
      alert('Error: ' + data.error);
    }
  } catch(err) {
    // Fall back to session-based if JWT not available — just reload
    window.location.reload();
  }
});

// Initial render
filterExercises();
</script>
</body>
</html>
