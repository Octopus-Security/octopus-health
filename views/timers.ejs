<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/theme.css">
  <style>
    .timer-tabs { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:24px; }
    .timer-tab  { padding:8px 18px; border-radius:8px; border:1px solid #2a2a2a; background:#0d0d0d; color:#888; font-size:0.85rem; cursor:pointer; transition:all 0.15s; }
    .timer-tab.active { background:#1a2a1a; border-color:#2ecc71; color:#2ecc71; font-weight:600; }
    .timer-panel { display:none; }
    .timer-panel.active { display:block; }
    .timer-display { font-size:5rem; font-weight:700; font-variant-numeric:tabular-nums; color:#e8e8e8; text-align:center; letter-spacing:4px; line-height:1; padding:32px 0 24px; }
    .timer-display.running { color:#2ecc71; }
    .timer-display.resting { color:#3498db; }
    .timer-display.warning { color:#e74c3c; }
    .timer-controls { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; margin-bottom:20px; }
    .timer-card { background:#0d0d0d; border:1px solid #1e1e1e; border-radius:14px; padding:24px; max-width:560px; margin:0 auto; }
    .config-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:20px; }
    .config-grid-3 { grid-template-columns:1fr 1fr 1fr; }
    .config-item label { display:block; font-size:0.75rem; color:#888; margin-bottom:4px; text-transform:uppercase; letter-spacing:0.5px; }
    .config-item input { width:100%; background:#141414; border:1px solid #2a2a2a; border-radius:8px; padding:10px 12px; color:#e8e8e8; font-size:1.1rem; text-align:center; font-variant-numeric:tabular-nums; }
    .config-item input:focus { outline:none; border-color:#2ecc71; }
    .round-info { text-align:center; font-size:0.9rem; color:#888; margin-bottom:8px; min-height:1.4em; }
    .phase-label { text-align:center; font-size:1.1rem; font-weight:600; text-transform:uppercase; letter-spacing:2px; margin-bottom:4px; min-height:1.4em; }
    .progress-bar-wrap { background:#1a1a1a; border-radius:4px; height:6px; overflow:hidden; margin-bottom:24px; }
    .progress-bar { height:100%; background:#2ecc71; transition:width 1s linear; border-radius:4px; }
    .progress-bar.rest { background:#3498db; }
    .btn-big { padding:12px 32px; font-size:1rem; border-radius:10px; }
    .stopwatch-laps { margin-top:16px; max-height:200px; overflow-y:auto; }
    .lap-row { display:flex; justify-content:space-between; padding:5px 0; border-bottom:1px solid #1a1a1a; font-size:0.85rem; color:#888; font-variant-numeric:tabular-nums; }
    .lap-row:last-child { border-bottom:none; }
    .lap-row .lap-num { color:#555; }
    .lap-row .lap-split { color:#aaa; }
    .lap-row .lap-total { color:#2ecc71; }
    .bell-flash { animation:flash 0.3s ease; }
    @keyframes flash { 0%,100%{opacity:1} 50%{opacity:0.2} }
    .combo-display { text-align:center; padding:28px 16px 12px; }
    .combo-numbers { font-size:4.5rem; font-weight:800; color:#e8e8e8; letter-spacing:6px; line-height:1; min-height:5.5rem; transition:opacity 0.15s; }
    .combo-numbers.flash-in { animation:comboFlash 0.25s ease; }
    @keyframes comboFlash { 0%{opacity:0;transform:scale(0.92)} 100%{opacity:1;transform:scale(1)} }
    .combo-labels { font-size:0.9rem; color:#555; margin-top:8px; min-height:1.4em; letter-spacing:1px; }
    .combo-strike { display:inline-block; padding:2px 0; transition:color 0.1s; }
    .combo-strike.active { color:#e74c3c; }
    .strike-toggles { display:flex; gap:10px; flex-wrap:wrap; justify-content:center; margin-bottom:16px; }
    .strike-toggle { display:flex; align-items:center; gap:6px; background:#0d0d0d; border:1px solid #2a2a2a; border-radius:8px; padding:6px 12px; cursor:pointer; font-size:0.82rem; color:#888; transition:all 0.15s; }
    .strike-toggle input { accent-color:#e74c3c; width:14px; height:14px; }
    .strike-toggle.on { border-color:#e74c3c44; color:#e07b54; }
    .cb-history { margin-top:16px; max-height:160px; overflow-y:auto; }
    .cb-history-row { padding:5px 0; border-bottom:1px solid #1a1a1a; font-size:0.82rem; color:#555; font-variant-numeric:tabular-nums; display:flex; gap:10px; }
    .cb-history-row:last-child { border-bottom:none; }
    .cb-history-row .cb-idx { color:#333; min-width:28px; }
    .cb-history-row .cb-combo { color:#888; }
    .cb-round-info { font-size:0.8rem; color:#3498db; text-align:center; min-height:1.2em; margin-bottom:4px; }
    .it-preset { background:#141414; border:1px solid #2a2a2a; border-radius:8px; padding:6px 12px; color:#888; font-size:0.8rem; cursor:pointer; transition:all 0.15s; display:flex; flex-direction:column; align-items:center; gap:2px; line-height:1.2; }
    .it-preset:hover { background:#1a2a1a; border-color:#2ecc71; color:#2ecc71; }
    .it-preset.bike { border-color:#2a3a4a; }
    .it-preset.bike:hover { background:#1a2a3a; border-color:#3498db; color:#3498db; }
    .it-preset span { font-size:0.68rem; color:#555; }
    .it-preset:hover span { color:inherit; opacity:0.7; }
  </style>
</head>
<body>
<%- include('partials/nav') %>

<div class="container" style="padding-top:24px">
  <h2 style="margin-bottom:20px">⏱ Timers</h2>

  <div class="timer-tabs">
    <button class="timer-tab active" data-panel="round">Round Timer</button>
    <button class="timer-tab" data-panel="interval">Interval</button>
    <button class="timer-tab" data-panel="emom">EMOM</button>
    <button class="timer-tab" data-panel="amrap">AMRAP</button>
    <button class="timer-tab" data-panel="stopwatch">Stopwatch</button>
    <button class="timer-tab" data-panel="combos" style="border-color:#3a1a1a;color:#e07b54" id="tab-combos">🥊 Combo Caller</button>
  </div>

  <!-- ── Round Timer ── -->
  <div class="timer-panel active" id="panel-round">
    <div class="timer-card">
      <div class="config-grid config-grid-3">
        <div class="config-item">
          <label>Rounds</label>
          <input type="number" id="rt-rounds" value="5" min="1" max="99">
        </div>
        <div class="config-item">
          <label>Round (min)</label>
          <input type="number" id="rt-work-min" value="3" min="0" max="60">
        </div>
        <div class="config-item">
          <label>Round (sec)</label>
          <input type="number" id="rt-work-sec" value="0" min="0" max="59">
        </div>
        <div class="config-item">
          <label>Rest (min)</label>
          <input type="number" id="rt-rest-min" value="1" min="0" max="60">
        </div>
        <div class="config-item">
          <label>Rest (sec)</label>
          <input type="number" id="rt-rest-sec" value="0" min="0" max="59">
        </div>
        <div class="config-item">
          <label>Countdown</label>
          <input type="number" id="rt-countdown" value="10" min="0" max="30">
        </div>
      </div>
      <div class="phase-label" id="rt-phase">—</div>
      <div class="round-info" id="rt-round-info"></div>
      <div class="timer-display" id="rt-display">0:00</div>
      <div class="progress-bar-wrap"><div class="progress-bar" id="rt-bar" style="width:100%"></div></div>
      <div class="timer-controls">
        <button class="btn btn-big" id="rt-start" onclick="rtStart()">▶ Start</button>
        <button class="btn btn-big" id="rt-pause" onclick="rtPause()" style="display:none">⏸ Pause</button>
        <button class="btn btn-big" onclick="rtReset()">↺ Reset</button>
      </div>
    </div>
  </div>

  <!-- ── Interval Timer ── -->
  <div class="timer-panel" id="panel-interval">
    <div class="timer-card">
      <!-- Quick presets -->
      <div style="margin-bottom:16px;">
        <div style="font-size:0.72rem;color:#555;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">Quick Presets</div>
        <div style="display:flex;gap:6px;flex-wrap:wrap;">
          <button class="it-preset" onclick="itPreset(8,20,10)">Tabata<span>20/10×8</span></button>
          <button class="it-preset" onclick="itPreset(10,30,30)">30/30<span>×10</span></button>
          <button class="it-preset" onclick="itPreset(10,40,20)">40/20<span>×10</span></button>
          <button class="it-preset" onclick="itPreset(10,45,15)">45/15<span>×10</span></button>
          <button class="it-preset bike" onclick="itPreset(10,10,50)">🚴 Bike Sprint<span>10/50×10</span></button>
          <button class="it-preset bike" onclick="itPreset(10,20,40)">🚴 Bike 20/40<span>×10</span></button>
          <button class="it-preset bike" onclick="itPreset(10,30,30)">🚴 Bike 30/30<span>×10</span></button>
          <button class="it-preset bike" onclick="itPreset(8,40,20)">🚴 Bike 40/20<span>×8</span></button>
        </div>
      </div>
      <div class="config-grid config-grid-3">
        <div class="config-item">
          <label>Rounds</label>
          <input type="number" id="it-rounds" value="8" min="1" max="99">
        </div>
        <div class="config-item">
          <label>Work (sec)</label>
          <input type="number" id="it-work" value="20" min="1" max="3600">
        </div>
        <div class="config-item">
          <label>Rest (sec)</label>
          <input type="number" id="it-rest" value="10" min="0" max="3600">
        </div>
      </div>
      <div class="phase-label" id="it-phase">—</div>
      <div class="round-info" id="it-round-info"></div>
      <div class="timer-display" id="it-display">0:00</div>
      <div class="progress-bar-wrap"><div class="progress-bar" id="it-bar" style="width:100%"></div></div>
      <div class="timer-controls">
        <button class="btn btn-big" id="it-start" onclick="itStart()">▶ Start</button>
        <button class="btn btn-big" id="it-pause" onclick="itPause()" style="display:none">⏸ Pause</button>
        <button class="btn btn-big" onclick="itReset()">↺ Reset</button>
      </div>
    </div>
  </div>

  <!-- ── EMOM ── -->
  <div class="timer-panel" id="panel-emom">
    <div class="timer-card">
      <div class="config-grid">
        <div class="config-item">
          <label>Minutes</label>
          <input type="number" id="em-minutes" value="10" min="1" max="60">
        </div>
        <div class="config-item">
          <label>Work (sec)</label>
          <input type="number" id="em-work" value="40" min="1" max="59">
        </div>
      </div>
      <div class="phase-label" id="em-phase">—</div>
      <div class="round-info" id="em-round-info"></div>
      <div class="timer-display" id="em-display">0:00</div>
      <div class="progress-bar-wrap"><div class="progress-bar" id="em-bar" style="width:100%"></div></div>
      <div class="timer-controls">
        <button class="btn btn-big" id="em-start" onclick="emStart()">▶ Start</button>
        <button class="btn btn-big" id="em-pause" onclick="emPause()" style="display:none">⏸ Pause</button>
        <button class="btn btn-big" onclick="emReset()">↺ Reset</button>
      </div>
    </div>
  </div>

  <!-- ── AMRAP ── -->
  <div class="timer-panel" id="panel-amrap">
    <div class="timer-card">
      <div class="config-grid">
        <div class="config-item">
          <label>Duration (min)</label>
          <input type="number" id="am-minutes" value="10" min="1" max="120">
        </div>
        <div class="config-item">
          <label>Duration (sec)</label>
          <input type="number" id="am-seconds" value="0" min="0" max="59">
        </div>
      </div>
      <div class="phase-label" id="am-phase">—</div>
      <div class="round-info" id="am-round-info"></div>
      <div class="timer-display" id="am-display">0:00</div>
      <div class="progress-bar-wrap"><div class="progress-bar" id="am-bar" style="width:100%"></div></div>
      <div class="timer-controls">
        <button class="btn btn-big" id="am-start" onclick="amStart()">▶ Start</button>
        <button class="btn btn-big" id="am-pause" onclick="amPause()" style="display:none">⏸ Pause</button>
        <button class="btn btn-big" onclick="amReset()">↺ Reset</button>
      </div>
    </div>
  </div>

  <!-- ── Combo Caller ── -->
  <div class="timer-panel" id="panel-combos">
    <div class="timer-card" style="max-width:640px">

      <!-- Strike toggles -->
      <div style="margin-bottom:16px">
        <div style="font-size:0.72rem;color:#555;text-transform:uppercase;letter-spacing:1px;text-align:center;margin-bottom:10px">Include strikes</div>
        <div class="strike-toggles">
          <label class="strike-toggle on" id="tog-1"><input type="checkbox" id="cb-1" checked> 1 Jab</label>
          <label class="strike-toggle on" id="tog-2"><input type="checkbox" id="cb-2" checked> 2 Cross</label>
          <label class="strike-toggle on" id="tog-3"><input type="checkbox" id="cb-3" checked> 3 Lead Hook</label>
          <label class="strike-toggle on" id="tog-4"><input type="checkbox" id="cb-4" checked> 4 Rear Hook</label>
          <label class="strike-toggle on" id="tog-5"><input type="checkbox" id="cb-5" checked> 5 Lead Upper</label>
          <label class="strike-toggle on" id="tog-6"><input type="checkbox" id="cb-6" checked> 6 Rear Upper</label>
          <label class="strike-toggle" id="tog-E"><input type="checkbox" id="cb-E"> Elbow</label>
          <label class="strike-toggle" id="tog-K"><input type="checkbox" id="cb-K"> Kick</label>
          <label class="strike-toggle" id="tog-N"><input type="checkbox" id="cb-N"> Knee</label>
        </div>
      </div>

      <!-- Config -->
      <div class="config-grid config-grid-3" style="margin-bottom:16px">
        <div class="config-item">
          <label>Min strikes</label>
          <input type="number" id="cb-min" value="2" min="1" max="6">
        </div>
        <div class="config-item">
          <label>Max strikes</label>
          <input type="number" id="cb-max" value="4" min="1" max="8">
        </div>
        <div class="config-item">
          <label>Delay (sec)</label>
          <input type="number" id="cb-delay" value="3" min="1" max="15">
        </div>
        <div class="config-item">
          <label>Rounds</label>
          <input type="number" id="cb-rounds" value="5" min="1" max="20">
        </div>
        <div class="config-item">
          <label>Round (min)</label>
          <input type="number" id="cb-rmin" value="3" min="1" max="10">
        </div>
        <div class="config-item">
          <label>Rest (sec)</label>
          <input type="number" id="cb-rest" value="60" min="0" max="180">
        </div>
      </div>

      <!-- Display -->
      <div class="cb-round-info" id="cb-round-info"></div>
      <div class="combo-display">
        <div class="combo-numbers" id="cb-numbers">—</div>
        <div class="combo-labels" id="cb-labels"></div>
      </div>

      <div class="timer-controls" style="margin-top:16px">
        <button class="btn btn-big" id="cb-start" onclick="cbStart()" style="background:#2a1a1a;border-color:#e74c3c;color:#e74c3c">▶ Start</button>
        <button class="btn btn-big" id="cb-pause" onclick="cbPause()" style="display:none">⏸ Pause</button>
        <button class="btn btn-big" onclick="cbReset()">↺ Reset</button>
        <button class="btn btn-big" id="cb-skip" onclick="cbSkip()" style="display:none;font-size:0.85rem">⏭ Next</button>
      </div>

      <div class="cb-history" id="cb-history"></div>
    </div>
  </div>

  <!-- ── Stopwatch ── -->
  <div class="timer-panel" id="panel-stopwatch">
    <div class="timer-card">
      <div class="timer-display" id="sw-display" style="font-size:4rem">0:00.0</div>
      <div class="timer-controls">
        <button class="btn btn-big" id="sw-start" onclick="swStart()">▶ Start</button>
        <button class="btn btn-big" id="sw-pause" onclick="swPause()" style="display:none">⏸ Pause</button>
        <button class="btn btn-big" id="sw-lap" onclick="swLap()" style="display:none">⊕ Lap</button>
        <button class="btn btn-big" onclick="swReset()">↺ Reset</button>
      </div>
      <div class="stopwatch-laps" id="sw-laps"></div>
    </div>
  </div>

</div>

<script>
// ── Tab switching ─────────────────────────────────────────────────────────────
document.querySelectorAll('.timer-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.timer-tab').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.timer-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('panel-' + btn.dataset.panel).classList.add('active');
  });
});

// ── Audio bell (Web Audio API) ────────────────────────────────────────────────
const ctx = new (window.AudioContext || window.webkitAudioContext)();
function playBell(freq=880, dur=0.4) {
  const osc = ctx.createOscillator();
  const gain = ctx.createGain();
  osc.connect(gain); gain.connect(ctx.destination);
  osc.frequency.value = freq;
  osc.type = 'sine';
  gain.gain.setValueAtTime(0.4, ctx.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + dur);
  osc.start(); osc.stop(ctx.currentTime + dur);
}
function playStartBell() { playBell(880, 0.5); }
function playEndBell()   { playBell(440, 0.8); setTimeout(() => playBell(440, 0.8), 400); }
function playCountBell() { playBell(660, 0.15); }

function fmt(s) {
  const m = Math.floor(s / 60);
  const sec = s % 60;
  return `${m}:${sec.toString().padStart(2,'0')}`;
}

// ── Round Timer ───────────────────────────────────────────────────────────────
let rtState = null;
let rtTick = null;
function rtGetConfig() {
  return {
    rounds:   parseInt(document.getElementById('rt-rounds').value)    || 5,
    workSec:  (parseInt(document.getElementById('rt-work-min').value)  || 0) * 60 +
              (parseInt(document.getElementById('rt-work-sec').value)  || 0),
    restSec:  (parseInt(document.getElementById('rt-rest-min').value)  || 0) * 60 +
              (parseInt(document.getElementById('rt-rest-sec').value)  || 0),
    countdown: parseInt(document.getElementById('rt-countdown').value) || 0,
  };
}
function rtStart() {
  ctx.resume();
  if (rtState && rtState.paused) { rtState.paused = false; rtTick = setInterval(rtTick_fn, 1000); document.getElementById('rt-start').style.display='none'; document.getElementById('rt-pause').style.display=''; return; }
  const cfg = rtGetConfig();
  rtState = { cfg, round:1, phase:'countdown', remaining: cfg.countdown || cfg.workSec, totalPhase: cfg.countdown || cfg.workSec, paused:false };
  if (cfg.countdown === 0) { rtState.phase = 'work'; playStartBell(); }
  rtRender();
  clearInterval(rtTick);
  rtTick = setInterval(rtTick_fn, 1000);
  document.getElementById('rt-start').style.display='none';
  document.getElementById('rt-pause').style.display='';
}
function rtTick_fn() {
  if (!rtState || rtState.paused) return;
  rtState.remaining--;
  if (rtState.remaining <= 0) { rtNextPhase(); } else { rtRender(); }
  if (rtState.remaining <= 3 && rtState.remaining > 0) playCountBell();
}
function rtNextPhase() {
  const { cfg } = rtState;
  if (rtState.phase === 'countdown') {
    rtState.phase = 'work'; rtState.remaining = cfg.workSec; rtState.totalPhase = cfg.workSec;
    playStartBell();
  } else if (rtState.phase === 'work') {
    playEndBell();
    if (rtState.round >= cfg.rounds) { rtDone(); return; }
    if (cfg.restSec > 0) { rtState.phase = 'rest'; rtState.remaining = cfg.restSec; rtState.totalPhase = cfg.restSec; }
    else { rtState.round++; rtState.phase = 'work'; rtState.remaining = cfg.workSec; rtState.totalPhase = cfg.workSec; playStartBell(); }
  } else if (rtState.phase === 'rest') {
    rtState.round++;
    rtState.phase = 'work'; rtState.remaining = cfg.workSec; rtState.totalPhase = cfg.workSec;
    playStartBell();
  }
  rtRender();
}
function rtDone() {
  clearInterval(rtTick);
  document.getElementById('rt-display').textContent = 'Done!';
  document.getElementById('rt-phase').textContent = '🏆 Workout Complete';
  document.getElementById('rt-bar').style.width = '0%';
  document.getElementById('rt-start').style.display='';
  document.getElementById('rt-pause').style.display='none';
  playEndBell(); setTimeout(playEndBell, 600);
  rtState = null;
}
function rtRender() {
  if (!rtState) return;
  const d = document.getElementById('rt-display');
  const b = document.getElementById('rt-bar');
  d.textContent = fmt(rtState.remaining);
  const pct = (rtState.remaining / rtState.totalPhase) * 100;
  b.style.width = pct + '%';
  if (rtState.phase === 'work') {
    d.className = 'timer-display running';
    b.className = 'progress-bar';
    document.getElementById('rt-phase').textContent = '🥊 ROUND ' + rtState.round;
    document.getElementById('rt-round-info').textContent = `Round ${rtState.round} of ${rtState.cfg.rounds}`;
  } else if (rtState.phase === 'rest') {
    d.className = 'timer-display resting';
    b.className = 'progress-bar rest';
    document.getElementById('rt-phase').textContent = '💤 REST';
    document.getElementById('rt-round-info').textContent = `Next: Round ${rtState.round + 1}`;
  } else {
    d.className = 'timer-display warning';
    document.getElementById('rt-phase').textContent = '⚡ GET READY';
    document.getElementById('rt-round-info').textContent = 'Starting soon…';
  }
}
function rtPause() {
  if (!rtState) return;
  rtState.paused = !rtState.paused;
  if (rtState.paused) { clearInterval(rtTick); document.getElementById('rt-pause').textContent='▶ Resume'; }
  else { rtTick = setInterval(rtTick_fn, 1000); document.getElementById('rt-pause').textContent='⏸ Pause'; }
}
function rtReset() {
  clearInterval(rtTick); rtState = null;
  document.getElementById('rt-display').textContent = '0:00';
  document.getElementById('rt-display').className = 'timer-display';
  document.getElementById('rt-phase').textContent = '—';
  document.getElementById('rt-round-info').textContent = '';
  document.getElementById('rt-bar').style.width = '100%';
  document.getElementById('rt-bar').className = 'progress-bar';
  document.getElementById('rt-start').style.display='';
  document.getElementById('rt-pause').style.display='none';
  document.getElementById('rt-pause').textContent='⏸ Pause';
}

// ── Interval Timer ────────────────────────────────────────────────────────────
let itState = null; let itTick = null;
function itPreset(rounds, work, rest) {
  document.getElementById('it-rounds').value = rounds;
  document.getElementById('it-work').value   = work;
  document.getElementById('it-rest').value   = rest;
  itReset();
}
function itStart() {
  ctx.resume();
  if (itState && itState.paused) { itState.paused=false; itTick=setInterval(itTick_fn,1000); document.getElementById('it-start').style.display='none'; document.getElementById('it-pause').style.display=''; return; }
  const rounds = parseInt(document.getElementById('it-rounds').value)||8;
  const work   = parseInt(document.getElementById('it-work').value)||20;
  const rest   = parseInt(document.getElementById('it-rest').value)||10;
  itState = { rounds, work, rest, round:1, phase:'work', remaining:work, totalPhase:work, paused:false };
  playStartBell(); itRender();
  clearInterval(itTick); itTick=setInterval(itTick_fn,1000);
  document.getElementById('it-start').style.display='none'; document.getElementById('it-pause').style.display='';
}
function itTick_fn() {
  if (!itState||itState.paused) return;
  itState.remaining--;
  if (itState.remaining<=0) { itNext(); } else { itRender(); }
  if (itState.remaining<=3&&itState.remaining>0) playCountBell();
}
function itNext() {
  if (itState.phase==='work') {
    playEndBell();
    if (itState.round>=itState.rounds) { itDone(); return; }
    if (itState.rest>0) { itState.phase='rest'; itState.remaining=itState.rest; itState.totalPhase=itState.rest; }
    else { itState.round++; itState.remaining=itState.work; itState.totalPhase=itState.work; playStartBell(); }
  } else {
    itState.round++; itState.phase='work'; itState.remaining=itState.work; itState.totalPhase=itState.work; playStartBell();
  }
  itRender();
}
function itDone() {
  clearInterval(itTick); itState=null;
  document.getElementById('it-display').textContent='Done!'; document.getElementById('it-phase').textContent='🏆 Complete';
  document.getElementById('it-start').style.display=''; document.getElementById('it-pause').style.display='none';
  playEndBell(); setTimeout(playEndBell,600);
}
function itRender() {
  if (!itState) return;
  const d=document.getElementById('it-display'), b=document.getElementById('it-bar');
  d.textContent=fmt(itState.remaining);
  b.style.width=(itState.remaining/itState.totalPhase*100)+'%';
  if (itState.phase==='work') {
    d.className='timer-display running'; b.className='progress-bar';
    document.getElementById('it-phase').textContent='💪 WORK';
    document.getElementById('it-round-info').textContent=`Round ${itState.round} of ${itState.rounds}`;
  } else {
    d.className='timer-display resting'; b.className='progress-bar rest';
    document.getElementById('it-phase').textContent='💤 REST';
    document.getElementById('it-round-info').textContent=`Next: Round ${itState.round+1}`;
  }
}
function itPause() {
  if (!itState) return;
  itState.paused=!itState.paused;
  if (itState.paused){clearInterval(itTick);document.getElementById('it-pause').textContent='▶ Resume';}
  else{itTick=setInterval(itTick_fn,1000);document.getElementById('it-pause').textContent='⏸ Pause';}
}
function itReset() {
  clearInterval(itTick); itState=null;
  document.getElementById('it-display').textContent='0:00'; document.getElementById('it-display').className='timer-display';
  document.getElementById('it-phase').textContent='—'; document.getElementById('it-round-info').textContent='';
  document.getElementById('it-bar').style.width='100%'; document.getElementById('it-bar').className='progress-bar';
  document.getElementById('it-start').style.display=''; document.getElementById('it-pause').style.display='none';
  document.getElementById('it-pause').textContent='⏸ Pause';
}

// ── EMOM ──────────────────────────────────────────────────────────────────────
let emState=null; let emTick=null;
function emStart() {
  ctx.resume();
  if (emState&&emState.paused){emState.paused=false;emTick=setInterval(emTick_fn,1000);document.getElementById('em-start').style.display='none';document.getElementById('em-pause').style.display='';return;}
  const totalMin=parseInt(document.getElementById('em-minutes').value)||10;
  const workSec =parseInt(document.getElementById('em-work').value)||40;
  emState={totalMin,workSec,minute:1,phase:'work',remaining:workSec,totalPhase:workSec,paused:false};
  playStartBell(); emRender();
  clearInterval(emTick); emTick=setInterval(emTick_fn,1000);
  document.getElementById('em-start').style.display='none'; document.getElementById('em-pause').style.display='';
}
function emTick_fn() {
  if (!emState||emState.paused) return;
  emState.remaining--;
  if (emState.remaining<=0){ emNext(); } else { emRender(); }
  if (emState.remaining<=3&&emState.remaining>0) playCountBell();
}
function emNext() {
  const restSec=60-emState.workSec;
  if (emState.phase==='work') {
    playEndBell();
    if (restSec>0){ emState.phase='rest'; emState.remaining=restSec; emState.totalPhase=restSec; }
    else{ if(emState.minute>=emState.totalMin){emDone();return;} emState.minute++; emState.phase='work'; emState.remaining=emState.workSec; emState.totalPhase=emState.workSec; playStartBell(); }
  } else {
    if (emState.minute>=emState.totalMin){ emDone(); return; }
    emState.minute++; emState.phase='work'; emState.remaining=emState.workSec; emState.totalPhase=emState.workSec; playStartBell();
  }
  emRender();
}
function emDone() {
  clearInterval(emTick); emState=null;
  document.getElementById('em-display').textContent='Done!'; document.getElementById('em-phase').textContent='🏆 EMOM Complete';
  document.getElementById('em-start').style.display=''; document.getElementById('em-pause').style.display='none';
  playEndBell(); setTimeout(playEndBell,600);
}
function emRender() {
  if (!emState) return;
  const d=document.getElementById('em-display'), b=document.getElementById('em-bar');
  d.textContent=fmt(emState.remaining);
  b.style.width=(emState.remaining/emState.totalPhase*100)+'%';
  if (emState.phase==='work'){
    d.className='timer-display running'; b.className='progress-bar';
    document.getElementById('em-phase').textContent='💪 WORK';
    document.getElementById('em-round-info').textContent=`Minute ${emState.minute} of ${emState.totalMin}`;
  } else {
    d.className='timer-display resting'; b.className='progress-bar rest';
    document.getElementById('em-phase').textContent='💤 REST';
    document.getElementById('em-round-info').textContent=`Next: Minute ${emState.minute+1}`;
  }
}
function emPause() {
  if (!emState) return;
  emState.paused=!emState.paused;
  if (emState.paused){clearInterval(emTick);document.getElementById('em-pause').textContent='▶ Resume';}
  else{emTick=setInterval(emTick_fn,1000);document.getElementById('em-pause').textContent='⏸ Pause';}
}
function emReset() {
  clearInterval(emTick); emState=null;
  document.getElementById('em-display').textContent='0:00'; document.getElementById('em-display').className='timer-display';
  document.getElementById('em-phase').textContent='—'; document.getElementById('em-round-info').textContent='';
  document.getElementById('em-bar').style.width='100%'; document.getElementById('em-bar').className='progress-bar';
  document.getElementById('em-start').style.display=''; document.getElementById('em-pause').style.display='none';
  document.getElementById('em-pause').textContent='⏸ Pause';
}

// ── AMRAP ─────────────────────────────────────────────────────────────────────
let amState=null; let amTick=null;
function amStart() {
  ctx.resume();
  if (amState&&amState.paused){amState.paused=false;amTick=setInterval(amTick_fn,1000);document.getElementById('am-start').style.display='none';document.getElementById('am-pause').style.display='';return;}
  const totalSec=(parseInt(document.getElementById('am-minutes').value)||10)*60+(parseInt(document.getElementById('am-seconds').value)||0);
  amState={totalSec,remaining:totalSec,paused:false};
  playStartBell(); amRender();
  clearInterval(amTick); amTick=setInterval(amTick_fn,1000);
  document.getElementById('am-start').style.display='none'; document.getElementById('am-pause').style.display='';
  document.getElementById('am-phase').textContent='⚡ GO!'; document.getElementById('am-round-info').textContent='As many rounds as possible';
}
function amTick_fn() {
  if (!amState||amState.paused) return;
  amState.remaining--;
  if (amState.remaining<=0){ amDone(); return; }
  if (amState.remaining<=10&&amState.remaining>0) playCountBell();
  amRender();
}
function amDone() {
  clearInterval(amTick); amState=null;
  document.getElementById('am-display').textContent='Time!'; document.getElementById('am-display').className='timer-display warning';
  document.getElementById('am-phase').textContent='🏆 Time\'s Up!';
  document.getElementById('am-start').style.display=''; document.getElementById('am-pause').style.display='none';
  playEndBell(); setTimeout(playEndBell,600);
}
function amRender() {
  if (!amState) return;
  const d=document.getElementById('am-display'), b=document.getElementById('am-bar');
  d.textContent=fmt(amState.remaining);
  d.className='timer-display running';
  b.style.width=(amState.remaining/amState.totalSec*100)+'%';
}
function amPause() {
  if (!amState) return;
  amState.paused=!amState.paused;
  if (amState.paused){clearInterval(amTick);document.getElementById('am-pause').textContent='▶ Resume';}
  else{amTick=setInterval(amTick_fn,1000);document.getElementById('am-pause').textContent='⏸ Pause';}
}
function amReset() {
  clearInterval(amTick); amState=null;
  document.getElementById('am-display').textContent='0:00'; document.getElementById('am-display').className='timer-display';
  document.getElementById('am-phase').textContent='—'; document.getElementById('am-round-info').textContent='';
  document.getElementById('am-bar').style.width='100%';
  document.getElementById('am-start').style.display=''; document.getElementById('am-pause').style.display='none';
  document.getElementById('am-pause').textContent='⏸ Pause';
}

// ── Stopwatch ─────────────────────────────────────────────────────────────────
let swRunning=false; let swStart=0; let swElapsed=0; let swTick=null; let swLapStart=0; let swLaps=[];
function fmtMs(ms) {
  const total=Math.floor(ms/100);
  const h=Math.floor(ms/3600000);
  const m=Math.floor((ms%3600000)/60000);
  const s=Math.floor((ms%60000)/1000);
  const t=Math.floor((ms%1000)/100);
  return (h>0?h+':':'') + (h>0?m.toString().padStart(2,'0'):m) + ':' + s.toString().padStart(2,'0') + '.' + t;
}
function swStart_() { // named to avoid collision with let swStart
  ctx.resume(); swRunning=true; swStart=Date.now()-swElapsed; swLapStart=swStart;
  clearInterval(swTick); swTick=setInterval(()=>{ swElapsed=Date.now()-swStart; document.getElementById('sw-display').textContent=fmtMs(swElapsed); },100);
  document.getElementById('sw-start').style.display='none'; document.getElementById('sw-pause').style.display=''; document.getElementById('sw-lap').style.display='';
}
function swPause() {
  if (swRunning){ swRunning=false; clearInterval(swTick); swElapsed=Date.now()-swStart; document.getElementById('sw-pause').textContent='▶ Resume'; }
  else { swStart_(); document.getElementById('sw-pause').textContent='⏸ Pause'; }
}
function swLap() {
  const lapMs=Date.now()-swStart-(swLapStart-swStart);
  swLaps.unshift({ n:swLaps.length+1, split:swElapsed, lap:lapMs });
  swLapStart=Date.now()-swStart;
  const el=document.getElementById('sw-laps');
  el.innerHTML=swLaps.map(l=>`<div class="lap-row"><span class="lap-num">Lap ${l.n}</span><span class="lap-split">${fmtMs(l.lap)}</span><span class="lap-total">→ ${fmtMs(l.split)}</span></div>`).join('');
}
function swReset() {
  clearInterval(swTick); swRunning=false; swElapsed=0; swLaps=[];
  document.getElementById('sw-display').textContent='0:00.0';
  document.getElementById('sw-laps').innerHTML='';
  document.getElementById('sw-start').style.display=''; document.getElementById('sw-pause').style.display='none'; document.getElementById('sw-lap').style.display='none';
  document.getElementById('sw-pause').textContent='⏸ Pause';
}
document.getElementById('sw-start').addEventListener('click', swStart_);

// ── Combo Caller ──────────────────────────────────────────────────────────────
const STRIKES = {
  '1': { label:'1', name:'Jab',           speak:'one'   },
  '2': { label:'2', name:'Cross',         speak:'two'   },
  '3': { label:'3', name:'Lead Hook',     speak:'three' },
  '4': { label:'4', name:'Rear Hook',     speak:'four'  },
  '5': { label:'5', name:'Lead Upper',    speak:'five'  },
  '6': { label:'6', name:'Rear Upper',    speak:'six'   },
  'E': { label:'E', name:'Elbow',         speak:'elbow' },
  'K': { label:'K', name:'Kick',          speak:'kick'  },
  'N': { label:'N', name:'Knee',          speak:'knee'  },
};

// Toggle styling on checkbox change
['1','2','3','4','5','6','E','K','N'].forEach(k => {
  const cb  = document.getElementById('cb-' + k);
  const tog = document.getElementById('tog-' + k);
  cb.addEventListener('change', () => tog.classList.toggle('on', cb.checked));
});

function cbGetPool() {
  return Object.keys(STRIKES).filter(k => document.getElementById('cb-' + k)?.checked);
}

function cbGenCombo(pool) {
  const min = parseInt(document.getElementById('cb-min').value) || 2;
  const max = parseInt(document.getElementById('cb-max').value) || 4;
  const len = min + Math.floor(Math.random() * (max - min + 1));
  const combo = [];
  for (let i = 0; i < len; i++) combo.push(pool[Math.floor(Math.random() * pool.length)]);
  return combo;
}

function cbSpeak(text) {
  if (!window.speechSynthesis) return;
  const u = new SpeechSynthesisUtterance(text);
  u.rate = 1.1; u.pitch = 1.0; u.volume = 1.0;
  speechSynthesis.speak(u);
}

function cbSpeakCombo(keys, callback) {
  // Speak each strike name with a short pause between them
  let i = 0;
  function next() {
    if (i >= keys.length) { if (callback) setTimeout(callback, 200); return; }
    const s = STRIKES[keys[i]];
    cbSpeak(s.speak);
    // Highlight active strike
    document.querySelectorAll('.combo-strike').forEach((el, idx) => {
      el.classList.toggle('active', idx === i);
    });
    i++;
    setTimeout(next, 420);
  }
  next();
}

let cbState = null;
let cbPhaseTimeout = null;
let cbComboTimeout = null;

function cbStart() {
  ctx.resume();
  if (cbState && cbState.paused) {
    cbState.paused = false;
    document.getElementById('cb-pause').textContent = '⏸ Pause';
    document.getElementById('cb-start').style.display = 'none';
    cbNextCombo();
    return;
  }
  const pool = cbGetPool();
  if (!pool.length) { alert('Enable at least one strike type.'); return; }
  cbState = {
    pool,
    rounds:     parseInt(document.getElementById('cb-rounds').value) || 5,
    roundSec:   (parseInt(document.getElementById('cb-rmin').value)  || 3) * 60,
    restSec:    parseInt(document.getElementById('cb-rest').value)   || 60,
    delaySec:   parseInt(document.getElementById('cb-delay').value)  || 3,
    round:      1,
    phase:      'work',
    roundEnd:   Date.now() + (parseInt(document.getElementById('cb-rmin').value)||3) * 60000,
    paused:     false,
    history:    [],
    comboCount: 0,
  };
  document.getElementById('cb-start').style.display = 'none';
  document.getElementById('cb-pause').style.display = '';
  document.getElementById('cb-skip').style.display  = '';
  document.getElementById('cb-history').innerHTML   = '';
  cbSpeak('Round ' + cbState.round);
  setTimeout(cbNextCombo, 1200);
}

function cbNextCombo() {
  if (!cbState || cbState.paused) return;

  // Check if current round has expired
  if (Date.now() >= cbState.roundEnd) {
    cbEndRound(); return;
  }

  const combo = cbGenCombo(cbState.pool);
  cbState.comboCount++;
  const numStr   = combo.map(k => STRIKES[k].label).join(' - ');
  const nameStr  = combo.map(k => STRIKES[k].name).join(' · ');

  // Display
  const numEl = document.getElementById('cb-numbers');
  numEl.className = 'combo-numbers';
  void numEl.offsetWidth; // reflow to restart animation
  numEl.className = 'combo-numbers flash-in';
  numEl.innerHTML = combo.map(k => `<span class="combo-strike">${STRIKES[k].label}</span>`).join('<span style="color:#333;margin:0 4px">—</span>');
  document.getElementById('cb-labels').textContent = nameStr;

  // Round info
  const secLeft = Math.max(0, Math.round((cbState.roundEnd - Date.now()) / 1000));
  document.getElementById('cb-round-info').textContent =
    `Round ${cbState.round} / ${cbState.rounds}  ·  ${fmt(secLeft)} left`;

  // History
  cbState.history.unshift({ n: cbState.comboCount, text: numStr + '  (' + nameStr + ')' });
  document.getElementById('cb-history').innerHTML = cbState.history.slice(0, 20).map(h =>
    `<div class="cb-history-row"><span class="cb-idx">#${h.n}</span><span class="cb-combo">${h.text}</span></div>`
  ).join('');

  // Speak then schedule next
  cbSpeakCombo(combo, () => {
    if (!cbState || cbState.paused) return;
    cbComboTimeout = setTimeout(cbNextCombo, cbState.delaySec * 1000);
  });
}

function cbEndRound() {
  if (!cbState) return;
  clearTimeout(cbComboTimeout);
  speechSynthesis.cancel();

  if (cbState.round >= cbState.rounds) {
    // Done
    document.getElementById('cb-numbers').textContent = '🏆';
    document.getElementById('cb-labels').textContent  = 'Workout complete!';
    document.getElementById('cb-round-info').textContent = '';
    cbSpeak('Workout complete. Great work.');
    cbReset(true);
    return;
  }

  // Rest phase
  cbState.round++;
  const restSec = cbState.restSec;
  document.getElementById('cb-numbers').textContent = fmt(restSec);
  document.getElementById('cb-numbers').className   = 'combo-numbers';
  document.getElementById('cb-labels').textContent  = 'Rest';
  document.getElementById('cb-round-info').textContent = `Round ${cbState.round} starts in…`;
  cbSpeak('Rest');

  let remaining = restSec;
  function restTick() {
    if (!cbState || cbState.paused) return;
    remaining--;
    document.getElementById('cb-numbers').textContent = fmt(remaining);
    if (remaining <= 3 && remaining > 0) cbSpeak(String(remaining));
    if (remaining <= 0) {
      cbSpeak('Round ' + cbState.round);
      cbState.roundEnd = Date.now() + cbState.roundSec * 1000;
      setTimeout(cbNextCombo, 1200);
    } else {
      cbPhaseTimeout = setTimeout(restTick, 1000);
    }
  }
  cbPhaseTimeout = setTimeout(restTick, 1000);
}

function cbPause() {
  if (!cbState) return;
  cbState.paused = !cbState.paused;
  if (cbState.paused) {
    clearTimeout(cbComboTimeout); clearTimeout(cbPhaseTimeout);
    speechSynthesis.cancel();
    document.getElementById('cb-pause').textContent = '▶ Resume';
    document.getElementById('cb-start').style.display = '';
  } else {
    document.getElementById('cb-pause').textContent = '⏸ Pause';
    document.getElementById('cb-start').style.display = 'none';
    cbNextCombo();
  }
}

function cbSkip() {
  clearTimeout(cbComboTimeout); clearTimeout(cbPhaseTimeout);
  speechSynthesis.cancel();
  if (cbState) cbNextCombo();
}

function cbReset(keepHistory) {
  clearTimeout(cbComboTimeout); clearTimeout(cbPhaseTimeout);
  speechSynthesis.cancel();
  cbState = null;
  if (!keepHistory) {
    document.getElementById('cb-numbers').textContent = '—';
    document.getElementById('cb-labels').textContent  = '';
    document.getElementById('cb-history').innerHTML   = '';
  }
  document.getElementById('cb-round-info').textContent = '';
  document.getElementById('cb-start').style.display = '';
  document.getElementById('cb-pause').style.display = 'none';
  document.getElementById('cb-skip').style.display  = 'none';
  document.getElementById('cb-pause').textContent   = '⏸ Pause';
}
</script>
