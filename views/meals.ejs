<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/theme.css">
</head>
<body>
    <nav>
        <div class="container">
            <h1>🏥 Health Tracker</h1>
            <div class="nav-links">
                <a href="/">Dashboard</a>
                <a href="/weight">Weight</a>
                <a href="/exercise">Exercise</a>
                <a href="/meals">Meals</a>
                <a href="/goals">Goals</a>
                <a href="/routines">Routines</a>
                <a href="/planner">Planner</a>
                <a href="/competitions">Competitions</a>
                <a href="/accountability">Accountability</a>
                <a href="/settings">Settings</a>
                <a href="/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="card">
            <h2>🍽️ Log Meal</h2>
            <form method="POST" action="/meals">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Date</label>
                        <input type="date" name="date" value="<%= new Date().toISOString().split('T')[0] %>" required>
                    </div>
                    <div class="form-group">
                        <label>Time</label>
                        <input type="time" name="time" value="<%= new Date().toTimeString().slice(0,5) %>" required>
                    </div>
                    <div class="form-group">
                        <label>Meal Type</label>
                        <select name="mealType" required>
                            <option value="breakfast">Breakfast</option>
                            <option value="lunch">Lunch</option>
                            <option value="dinner">Dinner</option>
                            <option value="snack">Snack</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Calories (optional)</label>
                        <input type="number" name="calories">
                    </div>
                    <div class="form-group">
                        <label>Protein (g) (optional)</label>
                        <input type="number" step="0.1" name="protein">
                    </div>
                    <div class="form-group">
                        <label>Carbs (g) (optional)</label>
                        <input type="number" step="0.1" name="carbs">
                    </div>
                    <div class="form-group">
                        <label>Fats (g) (optional)</label>
                        <input type="number" step="0.1" name="fats">
                    </div>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="description" rows="2" required placeholder="What did you eat?"></textarea>
                </div>
                <div class="form-group">
                    <label>Notes</label>
                    <textarea name="notes" rows="2"></textarea>
                </div>
                <button type="submit">Log Meal</button>
            </form>
        </div>

        <div class="card">
            <h2>Meal History</h2>
            <% if (meals.length > 0) { %>
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Calories</th>
                            <th>Macros (P/C/F)</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% meals.forEach(meal => { %>
                            <tr>
                                <td><%= new Date(meal.date).toLocaleDateString() %></td>
                                <td><%= meal.time %></td>
                                <td><%= meal.mealType %></td>
                                <td><%= meal.description.substring(0, 50) %><%= meal.description.length > 50 ? '...' : '' %></td>
                                <td><%= meal.calories || '-' %></td>
                                <td>
                                    <% if (meal.protein || meal.carbs || meal.fats) { %>
                                        <%= meal.protein || 0 %>/<%= meal.carbs || 0 %>/<%= meal.fats || 0 %>
                                    <% } else { %>
                                        -
                                    <% } %>
                                </td>
                                <td>
                                    <form method="POST" action="/meals/delete/<%= meal.id %>" style="display: inline;">
                                        <button type="submit" class="delete-btn">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <p class="empty-state">No meals logged yet. Add your first one above!</p>
            <% } %>
        </div>
    </div>
</body>
</html>
